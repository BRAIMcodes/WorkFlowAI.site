---
import '../styles/global.css';
import SubscribeModal from '../components/SubscribeModal.astro';
import Icon from '../components/Icon.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const { 
  title = "WorkFlowAI - The Wikipedia of AI Workflows & Automation Blueprints", 
  description = "Discover, copy-paste, and download production-ready AI workflows and automation blueprints for n8n, Make.com, HubSpot, and Claude.",
  ogImage = "/images/og-image.png"
} = Astro.props;

// Determine active nav path for active-state styling
const pathname = new URL(Astro.request.url).pathname;
const navLinks = [
  { href: '/workflows', label: 'Workflows' },
  { href: '/tools', label: 'Tools' },
  { href: '/personas', label: 'Personas' },
  { href: '/about', label: 'About' },
];
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <!-- Open Graph / Social SEO -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={Astro.url} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=3" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#6366F1" />
    <link rel="canonical" href={Astro.url.href} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    
    <!-- Google Fonts — Premium display + body combination -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap" rel="stylesheet">
    <link rel="preload" href="https://fonts.gstatic.com/s/inter/v18/UcCO3FwrK3iLTeHuS_nVMrMxCp50SjIw2boKoduKmMEVuLyfMZ0.woff2" as="font" type="font/woff2" crossorigin>
  </head>
  <body class="bg-[#070A13] text-gray-300 font-sans antialiased flex flex-col min-h-screen">
    
    <!-- Skip to content — accessibility fundamental -->
    <a href="#main-content" class="skip-to-content">Skip to content</a>

    <!-- Read Progress Bar -->
    <div id="read-progress" class="fixed top-0 left-0 h-0.5 bg-gradient-to-r from-indigo-500 via-violet-500 to-purple-500 z-[100] transition-all duration-150 ease-out" style="width: 0%;"></div>
    
    <!-- Translucent Navigation Header -->
    <header id="site-header" class="sticky top-0 z-50 transition-all duration-300">
      <!-- Backdrop: starts transparent, becomes frosted on scroll -->
      <div class="absolute inset-0 bg-[#070A13]/0 backdrop-blur-none border-b border-transparent transition-all duration-300" id="header-bg"></div>
      
      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-[68px]">
          
          <!-- Logo -->
          <div class="flex-shrink-0 flex items-center">
            <a href="/" class="flex items-center gap-3 group" aria-label="WorkFlowAI Home">
              <div class="w-9 h-9 bg-gradient-to-tr from-indigo-600 to-violet-500 rounded-xl flex items-center justify-center transform group-hover:scale-110 group-hover:rotate-3 transition-all duration-300 shadow-glow-indigo">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M13 3L4 14H12L11 21L20 10H12L13 3Z" fill="white" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <span class="text-[1.15rem] font-extrabold tracking-tight text-white font-display group-hover:text-white transition-colors">
                WorkFlow<span class="text-indigo-400">AI</span>
              </span>
            </a>
          </div>

          <!-- Desktop Navigation -->
          <nav class="hidden md:flex items-center gap-6" role="navigation" aria-label="Main navigation">
            {navLinks.map(link => (
              <a 
                href={link.href} 
                class={`nav-link ${pathname.startsWith(link.href) ? 'active' : ''}`}
              >
                {link.label}
              </a>
            ))}
            <a 
              href="/submit" 
              class={`nav-link ${pathname === '/submit' ? 'active' : ''}`}
              style="color: #818CF8"
            >
              Submit
            </a>
          </nav>

          <!-- CTA Button -->
          <div class="hidden md:flex items-center gap-3">
            <a 
              href="https://github.com/BRAIMcodes/WorkFlowAI.site" 
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 px-3.5 py-2 bg-white/5 hover:bg-white/8 border border-white/8 hover:border-white/12 rounded-xl text-xs font-semibold text-gray-300 hover:text-white transition-all duration-200"
              aria-label="View on GitHub"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
              </svg>
              Star on GitHub
            </a>
            <button 
              id="subscribe-nav-btn"
              onclick="window.openSubscribeModal()" 
              class="btn btn-primary text-xs px-4 py-2.5"
              aria-label="Subscribe for free"
            >
              Subscribe Free
            </button>
          </div>

          <!-- Mobile menu button -->
          <div class="md:hidden flex items-center">
            <button 
              id="mobile-menu-btn" 
              class="text-gray-300 hover:text-white focus:outline-none p-2 rounded-xl hover:bg-white/5 transition-colors"
              aria-label="Toggle mobile menu"
              aria-expanded="false"
              aria-controls="mobile-menu"
            >
              <svg id="menu-icon-open" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
              </svg>
              <svg id="menu-icon-close" class="h-5 w-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>
        </div>
      </div>

      <!-- Mobile Menu Overlay -->
      <div 
        id="mobile-menu" 
        class="hidden md:hidden absolute top-full left-0 w-full bg-[#070A13]/98 backdrop-blur-xl border-b border-white/5 shadow-2xl z-50"
        role="navigation"
        aria-label="Mobile navigation"
      >
        <nav class="max-w-7xl mx-auto px-4 sm:px-6 py-6 flex flex-col gap-1">
          {navLinks.map(link => (
            <a 
              href={link.href} 
              class={`flex items-center px-3 py-3 rounded-xl text-sm font-semibold transition-colors ${pathname.startsWith(link.href) ? 'bg-indigo-600/10 text-indigo-300' : 'text-gray-300 hover:bg-white/5 hover:text-white'}`}
            >
              {link.label}
            </a>
          ))}
          <a 
            href="/submit" 
            class={`flex items-center px-3 py-3 rounded-xl text-sm font-semibold transition-colors ${pathname === '/submit' ? 'bg-indigo-600/10 text-indigo-300' : 'text-indigo-400 hover:bg-indigo-600/10'}`}
          >
            Submit a Recipe
          </a>
          <div class="border-t border-white/5 mt-3 pt-4 flex flex-col gap-3">
            <button 
              onclick="window.openSubscribeModal()" 
              class="btn btn-primary w-full justify-center py-3"
            >
              Subscribe Free
            </button>
          </div>
        </nav>
      </div>
    </header>

    <!-- Main Content -->
    <main class="flex-grow" id="main-content">
      <slot />
    </main>

    <!-- Premium Dark Footer -->
    <footer class="bg-[#040609] border-t border-white/5 pt-16 pb-8 mt-auto">
      <!-- Subtle top shimmer for visual separation -->
      <div class="footer-shimmer mb-0 -mt-px"></div>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-2 md:grid-cols-5 gap-10 mb-14">
          
          <!-- Brand Column (spans 2 cols on md) -->
          <div class="col-span-2 md:col-span-2">
            <a href="/" class="flex items-center gap-2.5 mb-5 group w-fit">
              <div class="w-8 h-8 bg-gradient-to-tr from-indigo-600 to-violet-500 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform shadow-glow-indigo">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none">
                  <path d="M13 3L4 14H12L11 21L20 10H12L13 3Z" fill="white" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <span class="text-lg font-extrabold tracking-tight text-white font-display">
                WorkFlow<span class="text-indigo-400">AI</span>
              </span>
            </a>
            <p class="text-sm text-gray-500 leading-relaxed mb-5 max-w-xs">
              The Wikipedia of AI workflows. Production-ready automation blueprints for operations, marketing, and sales teams.
            </p>
            <!-- Social Links -->
            <div class="flex items-center gap-3">
              <a 
                href="https://github.com/BRAIMcodes/WorkFlowAI.site" 
                target="_blank" 
                rel="noopener noreferrer"
                class="w-9 h-9 rounded-xl bg-white/5 hover:bg-white/10 border border-white/5 hover:border-white/10 flex items-center justify-center text-gray-500 hover:text-white transition-all"
                aria-label="GitHub"
              >
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
                </svg>
              </a>
              <a 
                href="https://twitter.com/workflowai" 
                target="_blank" 
                rel="noopener noreferrer"
                class="w-9 h-9 rounded-xl bg-white/5 hover:bg-white/10 border border-white/5 hover:border-white/10 flex items-center justify-center text-gray-500 hover:text-white transition-all"
                aria-label="Twitter/X"
              >
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
              </a>
            </div>
          </div>

          <!-- Quick Links -->
          <div>
            <h3 class="text-[11px] font-bold text-gray-500 uppercase tracking-widest mb-5">Explore</h3>
            <ul class="space-y-3.5">
              <li><a href="/workflows" class="text-sm text-gray-500 hover:text-gray-200 transition-colors">All Workflows</a></li>
              <li><a href="/tools" class="text-sm text-gray-500 hover:text-gray-200 transition-colors">Tools Catalog</a></li>
              <li><a href="/personas" class="text-sm text-gray-500 hover:text-gray-200 transition-colors">By Role / Persona</a></li>
              <li><a href="/submit" class="text-sm text-indigo-500 hover:text-indigo-400 transition-colors font-medium">Submit a Recipe</a></li>
            </ul>
          </div>

          <!-- Company -->
          <div>
            <h3 class="text-[11px] font-bold text-gray-500 uppercase tracking-widest mb-5">Company</h3>
            <ul class="space-y-3.5">
              <li><a href="/about" class="text-sm text-gray-500 hover:text-gray-200 transition-colors">About</a></li>
              <li><a href="/contact" class="text-sm text-gray-500 hover:text-gray-200 transition-colors">Contact</a></li>
              <li><a href="/partners" class="text-sm text-gray-500 hover:text-gray-200 transition-colors">Partners</a></li>
            </ul>
          </div>

          <!-- Legal -->
          <div>
            <h3 class="text-[11px] font-bold text-gray-500 uppercase tracking-widest mb-5">Legal</h3>
            <ul class="space-y-3.5">
              <li><a href="/privacy" class="text-sm text-gray-500 hover:text-gray-200 transition-colors">Privacy Policy</a></li>
              <li><a href="/terms" class="text-sm text-gray-500 hover:text-gray-200 transition-colors">Terms of Service</a></li>
              <li><a href="/cookies" class="text-sm text-gray-500 hover:text-gray-200 transition-colors">Cookie Policy</a></li>
            </ul>
          </div>
        </div>

        <div class="section-divider mb-8"></div>
        
        <div class="flex flex-col md:flex-row justify-between items-center gap-4">
          <p class="text-xs text-gray-500">
            &copy; {new Date().getFullYear()} WorkFlowAI. Open-source for automators worldwide.
          </p>
          <div class="flex items-center gap-2 text-xs text-gray-500">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-500 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
            </span>
            All systems operational
          </div>
        </div>
      </div>
    </footer>

    <!-- Toast Notification Container -->
    <div id="toast-container" aria-live="polite" aria-atomic="true"></div>

    <!-- Cookie Consent Banner -->
    <div 
      id="cookie-consent-banner" 
      class="fixed bottom-5 left-4 right-4 md:left-auto md:right-5 md:max-w-[340px] glass-panel rounded-2xl p-5 shadow-2xl z-50 hidden"
      role="dialog"
      aria-label="Cookie consent"
      aria-live="polite"
    >
      <div class="flex items-start gap-3.5">
        <div class="mt-0.5 flex-shrink-0">
              <svg class="w-5 h-5 text-amber-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M9.5 9.5a1 1 0 1 0 0-.01"/><path d="M14 11a1 1 0 1 0 0-.01"/><path d="M8 14a1 1 0 1 0 0-.01"/><path d="M13 16a1 1 0 1 0 0-.01"/></svg>
            </div>
        <div class="flex-1 min-w-0">
          <p class="text-xs font-bold text-white mb-1">Cookie Preferences</p>
          <p class="text-xs text-gray-500 leading-relaxed mb-4">
            We use essential cookies to improve downloads and understand navigation.
          </p>
          <div class="flex gap-2">
            <button 
              id="accept-cookies" 
              class="btn btn-primary text-xs px-3.5 py-2"
            >
              Accept
            </button>
            <button 
              id="decline-cookies" 
              class="btn btn-ghost text-xs px-3.5 py-2 border border-white/8"
            >
              Decline
            </button>
          </div>
        </div>
      </div>
    </div>

    <SubscribeModal />

    <!-- Back to Top Button -->
    <button
      id="back-to-top"
      aria-label="Back to top"
      title="Back to top"
    >
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" />
      </svg>
    </button>

    <script is:inline>
      // ---- Global Toast Notification System ----
      window.showToast = function(message, type = 'info', duration = 3000) {
        const container = document.getElementById('toast-container');
        if (!container) return;
        const toast = document.createElement('div');
        toast.className = `toast toast-${type}`;
        toast.innerHTML = `
          <svg class="w-4 h-4 flex-shrink-0 ${type === 'success' ? 'text-emerald-400' : type === 'error' ? 'text-rose-400' : 'text-indigo-400'}" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            ${type === 'success' ? '<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>' : type === 'error' ? '<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>' : '<path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>'}
          </svg>
          <span>${message}</span>
        `;
        container.appendChild(toast);
        requestAnimationFrame(() => { requestAnimationFrame(() => toast.classList.add('show')); });
        setTimeout(() => {
          toast.classList.remove('show');
          setTimeout(() => toast.remove(), 400);
        }, duration);
      };

      // ---- Nav Active Header Scroll Effect ----
      const header = document.getElementById('site-header');
      const headerBg = document.getElementById('header-bg');
      
      window.addEventListener('scroll', () => {
        const scrolled = window.scrollY > 20;
        if (headerBg) {
          headerBg.style.backgroundColor = scrolled ? 'rgba(7, 10, 19, 0.92)' : 'rgba(7, 10, 19, 0)';
          headerBg.style.backdropFilter = scrolled ? 'blur(20px) saturate(180%)' : 'none';
          headerBg.style.borderBottomColor = scrolled ? 'rgba(255,255,255,0.06)' : 'transparent';
        }
      }, { passive: true });

      // ---- Reading Progress Bar (on article pages) ----
      const progressBar = document.getElementById('read-progress');
      if (progressBar && document.body.scrollHeight > window.innerHeight * 1.5) {
        window.addEventListener('scroll', () => {
          const scrollTop = window.scrollY;
          const docHeight = document.body.scrollHeight - window.innerHeight;
          const progress = Math.min((scrollTop / docHeight) * 100, 100);
          progressBar.style.width = progress + '%';
        }, { passive: true });
      }

      // ---- Mobile Menu Controller ----
      const mobileBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const iconOpen = document.getElementById('menu-icon-open');
      const iconClose = document.getElementById('menu-icon-close');
      
      if (mobileBtn && mobileMenu) {
        mobileBtn.addEventListener('click', () => {
          const isOpen = !mobileMenu.classList.contains('hidden');
          mobileMenu.classList.toggle('hidden');
          mobileBtn.setAttribute('aria-expanded', String(!isOpen));
          if (iconOpen) iconOpen.classList.toggle('hidden');
          if (iconClose) iconClose.classList.toggle('hidden');
        });
      }

      // ---- Back to Top ----
      const backToTop = document.getElementById('back-to-top');
      if (backToTop) {
        window.addEventListener('scroll', () => {
          if (window.scrollY > 400) {
            backToTop.classList.add('visible');
          } else {
            backToTop.classList.remove('visible');
          }
        }, { passive: true });
        backToTop.addEventListener('click', () => {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      }

      // ---- Cookie Consent Controller ----
      const consentBanner = document.getElementById('cookie-consent-banner');
      const acceptBtn = document.getElementById('accept-cookies');
      const declineBtn = document.getElementById('decline-cookies');

      if (consentBanner && acceptBtn && declineBtn) {
        const consent = localStorage.getItem('cookie-consent');
        if (!consent) {
          // Show after scroll 40% OR 12 seconds, whichever comes first
          let bannerShown = false;
          const showBanner = () => {
            if (!bannerShown) {
              bannerShown = true;
              consentBanner.classList.remove('hidden');
            }
          };

          const scrollTimer = setTimeout(showBanner, 12000);

          const scrollHandler = () => {
            const scrollPct = (window.scrollY / (document.body.scrollHeight - window.innerHeight)) * 100;
            if (scrollPct > 40) {
              clearTimeout(scrollTimer);
              showBanner();
              window.removeEventListener('scroll', scrollHandler);
            }
          };
          window.addEventListener('scroll', scrollHandler, { passive: true });
        }

        acceptBtn.addEventListener('click', () => {
          localStorage.setItem('cookie-consent', 'accepted');
          consentBanner.classList.add('hidden');
        });

        declineBtn.addEventListener('click', () => {
          localStorage.setItem('cookie-consent', 'declined');
          consentBanner.classList.add('hidden');
        });
      }

      // ---- Scroll Reveal (IntersectionObserver) ----
      const revealEls = document.querySelectorAll('.reveal');
      if (revealEls.length > 0 && 'IntersectionObserver' in window) {
        const revealObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('revealed');
              revealObserver.unobserve(entry.target);
            }
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
        revealEls.forEach(el => revealObserver.observe(el));
      } else {
        // Fallback: immediately reveal if no IntersectionObserver support
        revealEls.forEach(el => el.classList.add('revealed'));
      }

      // ---- Lazy Image Fade-In ----
      const lazyImgs = document.querySelectorAll('img[loading="lazy"]');
      lazyImgs.forEach(img => {
        if (img.complete) {
          img.classList.add('loaded');
        } else {
          img.addEventListener('load', () => img.classList.add('loaded'));
        }
      });
    </script>
  </body>
</html>
