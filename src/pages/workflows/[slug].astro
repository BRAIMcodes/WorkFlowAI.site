---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

// 1. Generate static pages for every entry in the workflows collection
export async function getStaticPaths() {
  const workflowEntries = await getCollection('workflows');
  return workflowEntries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { data } = entry;
const { Content } = await entry.render();

// 2. Query related workflows for programmatic SEO internal linking
const allWorkflows = await getCollection('workflows');

const relatedByTool = allWorkflows
  .filter(w => w.id !== entry.id && w.data.primaryTool === data.primaryTool)
  .slice(0, 2);

const relatedByPersona = allWorkflows
  .filter(w => w.id !== entry.id && w.data.persona === data.persona && !relatedByTool.find(r => r.id === w.id))
  .slice(0, 2);

// 3. Compile the HowTo JSON-LD schema
const schemaObj = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": data.title,
  "description": data.description,
  "estimatedCost": {
    "@type": "MonetaryAmount",
    "currency": "USD",
    "value": data.costToRun.includes("Free") ? "0.00" : "0.05"
  },
  "tool": [
    { "@type": "HowToTool", "name": data.primaryTool },
    ...data.connectedApps.map(app => ({ "@type": "HowToTool", "name": app }))
  ],
  "step": data.steps.map(step => ({
    "@type": "HowToStep",
    "position": step.stepNumber,
    "name": step.title,
    "text": step.description
  }))
};
---

<Layout title={`${data.title} | ${data.primaryTool} Recipe`} description={data.description}>
  <!-- Safe JSON-LD Schema Injection -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify(schemaObj)} />

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Breadcrumbs -->
    <nav class="text-xs text-gray-500 mb-6 flex items-center gap-2">
      <a href="/" class="hover:text-indigo-400 transition-colors">Home</a>
      <span>/</span>
      <a href="/workflows" class="hover:text-indigo-400 transition-colors">Workflows</a>
      <span>/</span>
      <span class="text-gray-300 font-medium truncate">{data.title}</span>
    </nav>

    <!-- Header Section -->
    <header class="border-b border-gray-800/80 pb-8 mb-10">
      <div class="flex flex-wrap gap-2 mb-4">
        <span class="px-2.5 py-0.5 bg-slate-900/60 border border-slate-800/80 text-[11px] font-semibold rounded-md text-slate-400">
          📂 {data.category}
        </span>
        <span class="px-2.5 py-0.5 bg-slate-900/60 border border-slate-800/80 text-[11px] font-semibold rounded-md text-slate-400">
          👤 For {data.persona}
        </span>
        <span class="px-2.5 py-0.5 bg-slate-900/60 border border-slate-800/80 text-[11px] font-semibold rounded-md text-slate-400">
          🔥 Level: {data.difficulty}
        </span>
      </div>

      <h1 class="text-3xl sm:text-5xl font-extrabold text-white tracking-tight leading-tight mb-4">
        {data.title}
      </h1>
      
      <p class="text-gray-400 text-base leading-relaxed mb-6">
        {data.description}
      </p>

      <!-- Key Metrics Box -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 bg-slate-900/40 border border-slate-800/80 rounded-2xl p-5">
        <div class="text-center sm:text-left border-b sm:border-b-0 sm:border-r border-slate-800/60 pb-4 sm:pb-0 sm:pr-4">
          <span class="text-[10px] text-gray-500 font-semibold uppercase tracking-wider block mb-1">⏱️ Est. Time Saved</span>
          <span class="text-lg font-bold text-emerald-400">{data.timeSaved}</span>
        </div>
        <div class="text-center sm:text-left border-b sm:border-b-0 sm:border-r border-slate-800/60 pb-4 sm:pb-0 sm:px-4">
          <span class="text-[10px] text-gray-500 font-semibold uppercase tracking-wider block mb-1">⚙️ Core Platform</span>
          <span class="text-lg font-bold text-white">{data.primaryTool}</span>
        </div>
        <div class="text-center sm:text-left sm:pl-4">
          <span class="text-[10px] text-gray-500 font-semibold uppercase tracking-wider block mb-1">💰 Estimated Run Cost</span>
          <span class="text-lg font-bold text-indigo-300">{data.costToRun}</span>
        </div>
      </div>
    </header>

    <!-- Download Blueprint Box -->
    <section class="bg-gradient-to-r from-indigo-950/20 to-violet-950/20 border border-indigo-500/15 rounded-2xl p-6 mb-12 flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="text-left">
        <h3 class="font-bold text-white text-md mb-1">Download Integration Assets</h3>
        <p class="text-xs text-gray-400">Import this verified blueprint file directly into your {data.primaryTool} dashboard.</p>
      </div>
      <a href={data.downloadUrl} download class="inline-flex justify-center items-center px-5 py-3 bg-indigo-600 hover:bg-indigo-550 text-white text-xs font-bold rounded-xl shadow-lg shadow-indigo-600/10 transition-all shrink-0 hover:-translate-y-0.5 btn-scale">
        📥 Download Blueprint
      </a>
    </section>

    <!-- Step-by-Step Vertical Connectors Timeline -->
    <section class="mb-12">
      <h2 class="text-xl md:text-2xl font-bold text-white mb-6">Execution Steps</h2>
      
      <!-- Connectors using dashed line -->
      <ol class="relative border-l border-slate-800 ml-4 space-y-6">
        {data.steps.map((step) => (
          <li class="relative pl-8" itemscope itemtype="https://schema.org/HowToStep">
            <!-- Numerical dot -->
            <span class="absolute flex items-center justify-center w-7 h-7 bg-gradient-to-tr from-indigo-600 to-violet-500 rounded-full -left-[14px] top-0 text-[10px] font-extrabold text-white shadow-md shadow-indigo-500/15">
              {step.stepNumber}
            </span>
            <div class="glass-panel p-5 rounded-2xl border border-gray-800/80">
              <h3 class="text-sm font-bold text-white mb-1.5" itemprop="name">
                {step.title}
              </h3>
              <p class="text-xs text-gray-400 leading-relaxed mb-3" itemprop="text">
                {step.description}
              </p>
              {step.tool && (
                <span class="inline-block px-2 py-0.5 bg-gray-950 border border-gray-800 rounded text-[9px] text-gray-500 font-semibold uppercase">
                  🔧 App: {step.tool}
                </span>
              )}
            </div>
          </li>
        ))}
      </ol>
    </section>

    <!-- Copyable AI System Prompt Code Block & Sandbox -->
    {data.promptSnippet && (
      <section class="mb-12">
        <h2 class="text-xl md:text-2xl font-bold text-white mb-6">Prompt Customizer Sandbox</h2>
        
        <div class={data.promptVariables ? "grid grid-cols-1 lg:grid-cols-3 gap-8" : "block"}>
          
          <!-- Variables Inputs (Form) -->
          {data.promptVariables && (
            <div class="lg:col-span-1 glass-panel p-5 rounded-2xl border border-gray-800/80 space-y-4 h-fit">
              <h3 class="text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-2">Variables</h3>
              {data.promptVariables.map(v => (
                <div>
                  <label for={`var-${v.name}`} class="block text-[10px] font-semibold text-gray-400 mb-1.5">{v.label}</label>
                  <input 
                    type="text" 
                    id={`var-${v.name}`} 
                    data-var-name={v.name}
                    placeholder={v.placeholder}
                    value={v.defaultValue}
                    class="prompt-var-input w-full bg-gray-950 border border-gray-800/80 rounded-xl px-3 py-2 text-xs text-white focus:outline-none focus:border-indigo-500/80 transition-colors"
                  />
                </div>
              ))}
            </div>
          )}

          <!-- Code Preview -->
          <div class={data.promptVariables ? "lg:col-span-2 space-y-3" : "w-full space-y-3"}>
            <div class="flex items-center justify-between">
              <span class="text-[10px] text-gray-500 font-bold uppercase tracking-wider">Prompt Preview</span>
              <button 
                id="copyBtn" 
                data-prompt={data.promptSnippet} 
                class="text-xs font-bold px-3 py-2 bg-gray-900 hover:bg-gray-850 border border-gray-800 text-gray-300 hover:text-white rounded-xl transition-all btn-scale"
              >
                📋 Copy Prompt
              </button>
            </div>
            <pre class="bg-gray-950 text-gray-300 p-5 rounded-2xl overflow-x-auto text-xs leading-relaxed whitespace-pre-wrap select-all border border-gray-800/80 font-mono"><code id="promptCode">{data.promptSnippet}</code></pre>
          </div>
        </div>
      </section>
    )}

    <!-- Main Markdown Body (Additional setups / configs) -->
    <section class="prose prose-invert prose-indigo max-w-none mb-12 border-t border-gray-800/80 pt-8 text-sm">
      <Content />
    </section>

    <!-- Flag/Works Feedback loop -->
    <footer class="border-t border-gray-800/80 pt-8 mt-12 flex flex-col sm:flex-row items-center justify-between gap-6">
      <div>
        <p class="text-sm text-gray-300 font-semibold mb-1">Did this blueprint break?</p>
        <p class="text-xs text-gray-500">AI integrations change quickly. Help us keep them working.</p>
      </div>
      <div class="flex gap-2">
        <button onclick="alert('Awesome! Glad to hear the recipe is working for you.')" class="px-4 py-2 border border-gray-800 rounded-xl text-xs font-semibold hover:bg-gray-900 text-gray-300 transition-colors btn-scale">
          👍 Works Perfect
        </button>
        <button onclick="alert('Thanks for the alert! Our community moderators will inspect and update this blueprint JSON.')" class="px-4 py-2 border border-red-950/40 rounded-xl text-xs font-semibold hover:bg-red-950/20 text-red-400 transition-colors btn-scale">
          🚨 Broken/Outdated
        </button>
      </div>
    </footer>

    <!-- Cross-Linking Block (SEO Topic Authority) -->
    <section class="border-t border-gray-800/80 pt-12 mt-12 grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- Related by Tool -->
      {relatedByTool.length > 0 && (
        <div>
          <h3 class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-4">Other {data.primaryTool} Blueprints</h3>
          <ul class="space-y-3">
            {relatedByTool.map(rel => (
              <li>
                <a href={`/workflows/${rel.id}`} class="block glass-panel p-4 rounded-xl border border-gray-800/80 text-xs text-gray-300 hover:text-white hover:border-gray-700 transition-all">
                  <span class="font-bold block mb-1">{rel.data.title}</span>
                  <span class="text-xs text-gray-500 line-clamp-1">{rel.data.description}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}

      <!-- Related by Persona -->
      {relatedByPersona.length > 0 && (
        <div>
          <h3 class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-4">Recommended for {data.persona}</h3>
          <ul class="space-y-3">
            {relatedByPersona.map(rel => (
              <li>
                <a href={`/workflows/${rel.id}`} class="block glass-panel p-4 rounded-xl border border-gray-800/80 text-xs text-gray-300 hover:text-white hover:border-gray-700 transition-all">
                  <span class="font-bold block mb-1">{rel.data.title}</span>
                  <span class="text-xs text-gray-500 line-clamp-1">{rel.data.description}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}
    </section>
  </div>
</Layout>

<script>
  const copyBtn = document.getElementById('copyBtn');
  const codeEl = document.getElementById('promptCode');
  const varInputs = document.querySelectorAll('.prompt-var-input') as NodeListOf<HTMLInputElement>;
  
  const baseTemplate = copyBtn ? copyBtn.getAttribute('data-prompt') || '' : '';

  function compilePrompt() {
    if (!copyBtn || !codeEl) return;
    let compiled = baseTemplate;

    varInputs.forEach(input => {
      const varName = input.getAttribute('data-var-name') || '';
      const value = input.value || input.placeholder || '';
      const regex = new RegExp(`\\[${varName}\\]`, 'g');
      compiled = compiled.replace(regex, value);
    });

    codeEl.textContent = compiled;
    copyBtn.setAttribute('data-prompt', compiled);
  }

  varInputs.forEach(input => {
    input.addEventListener('input', compilePrompt);
  });

  if (varInputs.length > 0) {
    compilePrompt();
  }

  if (copyBtn) {
    copyBtn.addEventListener('click', () => {
      const textToCopy = copyBtn.getAttribute('data-prompt') || '';
      navigator.clipboard.writeText(textToCopy).then(() => {
        copyBtn.textContent = '✅ Copied!';
        copyBtn.classList.add('bg-emerald-950', 'text-emerald-400', 'border-emerald-800');
        setTimeout(() => {
          copyBtn.textContent = '📋 Copy Prompt';
          copyBtn.classList.remove('bg-emerald-950', 'text-emerald-400', 'border-emerald-800');
        }, 2000);
      }).catch(err => {
        console.error('Failed to copy: ', err);
      });
    });
  }
</script>
