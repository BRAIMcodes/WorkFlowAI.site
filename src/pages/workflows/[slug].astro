---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Icon from '../../components/Icon.astro';

// 1. Generate static pages for every entry in the workflows collection
export async function getStaticPaths() {
  const workflowEntries = await getCollection('workflows');
  return workflowEntries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { data } = entry;
const { Content } = await entry.render();

// 2. Query related workflows for programmatic SEO internal linking
const allWorkflows = await getCollection('workflows');

const relatedByTool = allWorkflows
  .filter(w => w.id !== entry.id && w.data.primaryTool === data.primaryTool)
  .slice(0, 2);

const relatedByPersona = allWorkflows
  .filter(w => w.id !== entry.id && w.data.persona === data.persona && !relatedByTool.find(r => r.id === w.id))
  .slice(0, 2);

// 3. Compile the HowTo JSON-LD schema
const schemaObj = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": data.title,
  "description": data.description,
  "estimatedCost": {
    "@type": "MonetaryAmount",
    "currency": "USD",
    "value": data.costToRun.includes("Free") ? "0.00" : "0.05"
  },
  "tool": [
    { "@type": "HowToTool", "name": data.primaryTool },
    ...data.connectedApps.map((app: string) => ({ "@type": "HowToTool", "name": app }))
  ],
  "step": data.steps.map((step: any) => ({
    "@type": "HowToStep",
    "position": step.stepNumber,
    "name": step.title,
    "text": step.description
  }))
};

const difficultyClass = 
  data.difficulty === 'Beginner' ? 'difficulty-beginner' :
  data.difficulty === 'Advanced' ? 'difficulty-advanced' :
  'difficulty-intermediate';
---

<Layout title={`${data.title} | ${data.primaryTool} Recipe`} description={data.description}>
  <!-- Safe JSON-LD Schema Injection -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify(schemaObj)} />

  <!-- Page Layout -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-1.5 text-xs text-gray-500 mb-8" aria-label="Breadcrumb">
      <a href="/" class="hover:text-indigo-400 transition-colors">Home</a>
      <span class="text-gray-500" aria-hidden="true">/</span>
      <a href="/workflows" class="hover:text-indigo-400 transition-colors">Workflows</a>
      <span class="text-gray-500" aria-hidden="true">/</span>
      <span class="text-gray-400 font-medium truncate max-w-[200px]" aria-current="page">{data.title}</span>
    </nav>

    <!-- ============================================================
         HEADER
         ============================================================ -->
    <header class="mb-10">
      <!-- Badge row -->
      <div class="flex flex-wrap gap-2 mb-5">
        <span class="badge badge-indigo"><Icon name="folder" class="w-3 h-3" /> {data.category}</span>
        <span class="badge badge-slate"><Icon name="user" class="w-3 h-3" /> For {data.persona}</span>
        <span class={`badge ${difficultyClass}`}><Icon name="flame" class="w-3 h-3" /> {data.difficulty}</span>
        <!-- Trust signal: verified badge -->
        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg bg-emerald-500/8 border border-emerald-500/15 text-[11px] font-semibold text-emerald-400">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"/>
          </svg>
          Verified {data.lastVerified || 'June 2026'}
        </span>
      </div>

      <!-- Title -->
      <h1 class="font-display text-3xl sm:text-4xl md:text-5xl font-extrabold text-white tracking-tight leading-tight mb-4">
        {data.title}
      </h1>
      
      <!-- Description -->
      <p class="text-gray-400 text-base leading-relaxed mb-7 max-w-2xl">
        {data.description}
      </p>

      <!-- Key Metrics — 4 pillars -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-px bg-white/5 rounded-2xl overflow-hidden border border-white/5">
        <div class="bg-[#0B0F19] p-5 hover:bg-[#0F1525] transition-colors">
          <span class="text-[10px] font-bold text-gray-500 uppercase tracking-widest block mb-2">Time Saved</span>
          <span class="text-lg font-extrabold text-emerald-400 font-display">{data.timeSaved}</span>
        </div>
        <div class="bg-[#0B0F19] p-5 hover:bg-[#0F1525] transition-colors">
          <span class="text-[10px] font-bold text-gray-500 uppercase tracking-widest block mb-2">Setup Time</span>
          <span class="text-lg font-extrabold text-indigo-300 font-display">{data.setupTime || '~30 min'}</span>
        </div>
        <div class="bg-[#0B0F19] p-5 hover:bg-[#0F1525] transition-colors">
          <span class="text-[10px] font-bold text-gray-500 uppercase tracking-widest block mb-2">Platform</span>
          <span class="text-lg font-extrabold text-white font-display">{data.primaryTool}</span>
        </div>
        <div class="bg-[#0B0F19] p-5 hover:bg-[#0F1525] transition-colors">
          <span class="text-[10px] font-bold text-gray-500 uppercase tracking-widest block mb-2">Run Cost</span>
          <span class="text-lg font-extrabold text-amber-300 font-display">{data.costToRun}</span>
        </div>
      </div>
    </header>

    <!-- ============================================================
         DOWNLOAD BLUEPRINT CTA
         ============================================================ -->
    <section class="relative rounded-2xl overflow-hidden mb-12" aria-labelledby="download-heading">
      <div class="absolute inset-0 bg-gradient-to-r from-indigo-950/50 to-violet-950/30"></div>
      <div class="absolute inset-0 border border-indigo-500/15 rounded-2xl"></div>
      <div class="relative z-10 p-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-5">
        <div>
          <h2 id="download-heading" class="font-display font-bold text-white text-base mb-1">Download Integration Assets</h2>
          <p class="text-xs text-gray-500">Import this verified blueprint directly into your {data.primaryTool} dashboard.</p>
        </div>
        <a 
          href={data.downloadUrl} 
          download 
          class="btn btn-primary text-xs flex-shrink-0"
          aria-label={`Download ${data.primaryTool} blueprint for ${data.title}`}
        >
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
          Download Blueprint
        </a>
      </div>
    </section>

    <!-- ============================================================
         CONNECTED APPS
         ============================================================ -->
    {data.connectedApps && data.connectedApps.length > 0 && (
      <section class="mb-12">
        <h2 class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-4">Connected Apps</h2>
        <div class="flex flex-wrap gap-2">
          {data.connectedApps.map((app: string) => (
            <span class="badge badge-slate">{app}</span>
          ))}
        </div>
      </section>
    )}

    <!-- ============================================================
         STEP-BY-STEP TIMELINE
         ============================================================ -->
    <section class="mb-14" aria-labelledby="steps-heading">
      <h2 id="steps-heading" class="font-display text-xl md:text-2xl font-bold text-white mb-8">Execution Steps</h2>

      <ol class="relative space-y-4 ml-3" aria-label="Workflow steps">
        {data.steps.map((step: any, index: number) => (
          <li class="relative pl-12" itemscope itemtype="https://schema.org/HowToStep">
            <!-- Timeline left-side vertical line -->
            {index < data.steps.length - 1 && (
              <div class="step-connector" aria-hidden="true"></div>
            )}
            
            <!-- Step number bubble -->
            <div 
              class="absolute left-0 top-0 w-8 h-8 bg-gradient-to-br from-indigo-600 to-violet-600 rounded-xl flex items-center justify-center text-[10px] font-extrabold text-white shadow-lg shadow-indigo-600/20 z-10"
              aria-hidden="true"
            >
              {step.stepNumber}
            </div>

            <!-- Step card -->
            <div class="glass-card rounded-2xl p-5 border border-white/4 group">
              <div class="flex items-start justify-between gap-4">
                <div class="flex-1 min-w-0">
                  <h3 class="text-sm font-bold text-white mb-2 group-hover:text-indigo-300 transition-colors" itemprop="name">
                    {step.title}
                  </h3>
                  <p class="text-xs text-gray-500 leading-relaxed" itemprop="text">
                    {step.description}
                  </p>
                </div>
              </div>
              {step.tool && (
                <div class="mt-3 pt-3 border-t border-white/4">
                  <span class="badge badge-slate"><Icon name="wrench" class="w-3 h-3" /> {step.tool}</span>
                </div>
              )}
            </div>
          </li>
        ))}
      </ol>
    </section>

    <!-- ============================================================
         PROMPT SANDBOX
         ============================================================ -->
    {data.promptSnippet && (
      <section class="mb-14" aria-labelledby="sandbox-heading">
        <h2 id="sandbox-heading" class="font-display text-xl md:text-2xl font-bold text-white mb-6">
          Prompt Customizer Sandbox
        </h2>
        
        <div class={data.promptVariables ? "grid grid-cols-1 lg:grid-cols-3 gap-6" : "block"}>
          
          <!-- Variables Form -->
          {data.promptVariables && (
            <div class="lg:col-span-1 glass-panel p-5 rounded-2xl border border-white/5 space-y-4 h-fit">
              <h3 class="text-[10px] font-bold text-gray-500 uppercase tracking-widest">Variables</h3>
              {data.promptVariables.map((v: any) => (
                <div>
                  <label for={`var-${v.name}`} class="block text-[11px] font-semibold text-gray-500 mb-1.5 uppercase tracking-wider">{v.label}</label>
                  <input 
                    type="text" 
                    id={`var-${v.name}`} 
                    data-var-name={v.name}
                    placeholder={v.placeholder}
                    value={v.defaultValue}
                    class="prompt-var-input w-full bg-[#141C2E] border border-white/6 rounded-xl px-3 py-2.5 text-xs text-white focus:outline-none focus:border-indigo-500/50 transition-colors placeholder-gray-500"
                    aria-label={v.label}
                  />
                </div>
              ))}
            </div>
          )}

          <!-- Code Preview -->
          <div class={data.promptVariables ? "lg:col-span-2 space-y-3" : "w-full space-y-3"}>
            <div class="flex items-center justify-between">
              <span class="text-[10px] text-gray-500 font-bold uppercase tracking-widest">Prompt Preview</span>
              <button 
                id="copyBtn" 
                data-prompt={data.promptSnippet}
                class="btn btn-secondary text-xs px-3.5 py-2"
                aria-label="Copy prompt to clipboard"
              >
                <svg class="w-3.5 h-3.5 copy-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                </svg>
                <span class="copy-label">Copy Prompt</span>
              </button>
            </div>
            <pre class="bg-[#0A0E1A] text-gray-300 p-5 rounded-2xl overflow-x-auto text-xs leading-relaxed whitespace-pre-wrap border border-white/5 font-mono min-h-[120px]" aria-label="Prompt preview"><code id="promptCode">{data.promptSnippet}</code></pre>
          </div>
        </div>
      </section>
    )}

    <!-- ============================================================
         MARKDOWN CONTENT
         ============================================================ -->
    <section class="prose prose-invert prose-indigo max-w-none mb-14 pt-8 border-t border-white/5 text-sm leading-relaxed">
      <Content />
    </section>

    <!-- ============================================================
         FEEDBACK LOOP
         ============================================================ -->
    <div class="border-t border-white/5 pt-8 mb-14 flex flex-col sm:flex-row items-center justify-between gap-5">
      <div>
        <p class="text-sm font-bold text-gray-300 mb-0.5">Did this blueprint work for you?</p>
        <p class="text-xs text-gray-500">AI integrations change fast. Help keep recipes accurate.</p>
      </div>
      <div class="flex gap-2">
        <button 
          onclick="this.disabled=true; this.style.opacity='0.6'; window.showToast && window.showToast('Thanks for the feedback! Blueprint verified ✓', 'success');" 
          class="btn btn-secondary text-xs px-4 py-2.5"
          aria-label="Mark as working"
        >
          <Icon name="thumbs-up" class="w-3.5 h-3.5" /> Works!
        </button>
        <button 
          onclick="this.disabled=true; this.style.opacity='0.6'; window.showToast && window.showToast('Flagged for review. We\u2019ll update this soon.', 'error');"
          class="px-4 py-2.5 border border-red-500/20 rounded-xl text-xs font-bold hover:bg-red-950/20 text-red-400/80 transition-colors"
          aria-label="Mark as broken or outdated"
        >
          <Icon name="alert-triangle" class="w-3.5 h-3.5" /> Broken
        </button>
      </div>
    </div>

    <!-- ============================================================
         RELATED WORKFLOWS
         ============================================================ -->
    {(relatedByTool.length > 0 || relatedByPersona.length > 0) && (
      <section class="border-t border-white/5 pt-10" aria-labelledby="related-heading">
        <h2 id="related-heading" class="font-display text-lg font-bold text-white mb-7">Related Blueprints</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <!-- Related by Tool -->
          {relatedByTool.length > 0 && (
            <div>
              <h3 class="text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-3">More {data.primaryTool} Blueprints</h3>
              <ul class="space-y-2">
                {relatedByTool.map(rel => (
                  <li>
                    <a 
                      href={`/workflows/${rel.id}`} 
                      class="block glass-card rounded-xl p-4 border border-white/4 text-xs text-gray-400 hover:text-white transition-all group"
                    >
                      <span class="font-bold block mb-1 text-gray-200 group-hover:text-indigo-300 transition-colors">{rel.data.title}</span>
                      <span class="text-gray-500 line-clamp-1">{rel.data.description}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}

          <!-- Related by Persona -->
          {relatedByPersona.length > 0 && (
            <div>
              <h3 class="text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-3">Recommended for {data.persona}</h3>
              <ul class="space-y-2">
                {relatedByPersona.map(rel => (
                  <li>
                    <a 
                      href={`/workflows/${rel.id}`} 
                      class="block glass-card rounded-xl p-4 border border-white/4 text-xs text-gray-400 hover:text-white transition-all group"
                    >
                      <span class="font-bold block mb-1 text-gray-200 group-hover:text-indigo-300 transition-colors">{rel.data.title}</span>
                      <span class="text-gray-500 line-clamp-1">{rel.data.description}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </section>
    )}
  </div>
</Layout>

<script>
  const copyBtn = document.getElementById('copyBtn') as HTMLButtonElement;
  const codeEl = document.getElementById('promptCode');
  const varInputs = document.querySelectorAll('.prompt-var-input') as NodeListOf<HTMLInputElement>;
  
  const baseTemplate = copyBtn ? copyBtn.getAttribute('data-prompt') || '' : '';

  function compilePrompt() {
    if (!copyBtn || !codeEl) return;
    let compiled = baseTemplate;

    varInputs.forEach(input => {
      const varName = input.getAttribute('data-var-name') || '';
      const value = input.value || input.placeholder || '';
      const regex = new RegExp(`\\[${varName}\\]`, 'g');
      compiled = compiled.replace(regex, value);
    });

    codeEl.textContent = compiled;
    copyBtn.setAttribute('data-prompt', compiled);
  }

  varInputs.forEach(input => {
    input.addEventListener('input', compilePrompt);
  });

  if (varInputs.length > 0) {
    compilePrompt();
  }

  if (copyBtn) {
    copyBtn.addEventListener('click', () => {
      const textToCopy = copyBtn.getAttribute('data-prompt') || '';
      const copyLabel = copyBtn.querySelector('.copy-label');
      const copyIcon = copyBtn.querySelector('.copy-icon');

      navigator.clipboard.writeText(textToCopy).then(() => {
        if (copyLabel) copyLabel.textContent = 'Copied!';
        if (copyIcon) {
          (copyIcon as HTMLElement).innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />`;
        }
        copyBtn.classList.add('border-emerald-500/25', 'text-emerald-400');
        copyBtn.classList.remove('text-gray-300');
        
        setTimeout(() => {
          if (copyLabel) copyLabel.textContent = 'Copy Prompt';
          if (copyIcon) {
            (copyIcon as HTMLElement).innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />`;
          }
          copyBtn.classList.remove('border-emerald-500/25', 'text-emerald-400');
          copyBtn.classList.add('text-gray-300');
        }, 2000);
      }).catch(err => {
        console.error('Failed to copy:', err);
      });
    });
  }
</script>
