---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const workflows = await getCollection('workflows');

// Gather lists of all categories, tools, and personas for the filter sidebar
const categories = [...new Set(workflows.map(w => w.data.category))];
const tools = [...new Set(workflows.map(w => w.data.primaryTool))];
const personas = [...new Set(workflows.map(w => w.data.persona))];
---

<Layout title="AI Automation Workflow Library & Recipes - WorkFlowAI" description="Browse our complete list of verified automation blueprints, JSON configurations, and prompt scripts for n8n, Make.com, and Claude.">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Header Section -->
    <div class="border-b border-gray-800 pb-8 mb-10">
      <h1 class="text-3xl md:text-5xl font-extrabold text-white mb-4">Automation Blueprints</h1>
      <p class="text-gray-400 text-lg max-w-3xl">
        Filter by department, primary automation tool, or search for specific integrations to find your recipe.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
      
      <!-- Filters Sidebar (Client-side control) -->
      <aside class="col-span-1 space-y-8">
        <!-- Search Widget -->
        <div class="glass-panel p-5 rounded-2xl border border-gray-800">
          <h3 class="text-sm font-bold text-gray-300 uppercase tracking-wider mb-3">Search</h3>
          <div class="relative">
            <input 
              type="text" 
              id="search-input" 
              placeholder="Search blueprints..." 
              class="w-full bg-gray-950 border border-gray-800 rounded-xl px-4 py-2.5 text-sm text-white focus:outline-none focus:border-indigo-500/80 transition-colors"
            />
          </div>
        </div>

        <!-- Tool Filter -->
        <div class="glass-panel p-5 rounded-2xl border border-gray-800">
          <h3 class="text-sm font-bold text-gray-300 uppercase tracking-wider mb-3">Automation Tool</h3>
          <div class="space-y-2.5">
            <label class="flex items-center gap-3 text-sm text-gray-400 hover:text-white cursor-pointer select-none">
              <input type="radio" name="tool-filter" value="all" checked class="rounded bg-gray-950 border-gray-800 text-indigo-600 focus:ring-0" />
              All Tools
            </label>
            {tools.map(tool => (
              <label class="flex items-center gap-3 text-sm text-gray-400 hover:text-white cursor-pointer select-none">
                <input type="radio" name="tool-filter" value={tool} class="rounded bg-gray-950 border-gray-800 text-indigo-600 focus:ring-0" />
                {tool}
              </label>
            ))}
          </div>
        </div>

        <!-- Category Filter -->
        <div class="glass-panel p-5 rounded-2xl border border-gray-800">
          <h3 class="text-sm font-bold text-gray-300 uppercase tracking-wider mb-3">Category</h3>
          <div class="space-y-2.5">
            <label class="flex items-center gap-3 text-sm text-gray-400 hover:text-white cursor-pointer select-none">
              <input type="radio" name="category-filter" value="all" checked class="rounded bg-gray-950 border-gray-800 text-indigo-600 focus:ring-0" />
              All Categories
            </label>
            {categories.map(cat => (
              <label class="flex items-center gap-3 text-sm text-gray-400 hover:text-white cursor-pointer select-none">
                <input type="radio" name="category-filter" value={cat} class="rounded bg-gray-950 border-gray-800 text-indigo-600 focus:ring-0" />
                {cat}
              </label>
            ))}
          </div>
        </div>

        <!-- Persona Filter -->
        <div class="glass-panel p-5 rounded-2xl border border-gray-800">
          <h3 class="text-sm font-bold text-gray-300 uppercase tracking-wider mb-3">Persona</h3>
          <div class="space-y-2.5">
            <label class="flex items-center gap-3 text-sm text-gray-400 hover:text-white cursor-pointer select-none">
              <input type="radio" name="persona-filter" value="all" checked class="rounded bg-gray-950 border-gray-800 text-indigo-600 focus:ring-0" />
              All Roles
            </label>
            {personas.map(pers => (
              <label class="flex items-center gap-3 text-sm text-gray-400 hover:text-white cursor-pointer select-none">
                <input type="radio" name="persona-filter" value={pers} class="rounded bg-gray-950 border-gray-800 text-indigo-600 focus:ring-0" />
                For {pers}
              </label>
            ))}
          </div>
        </div>
      </aside>

      <!-- Workflows Grid -->
      <main class="col-span-1 lg:col-span-3">
        <!-- Results Counter -->
        <div class="flex justify-between items-center mb-6">
          <span id="results-count" class="text-sm text-gray-500 font-semibold">Showing {workflows.length} workflows</span>
          <button id="clear-filters" class="hidden text-xs text-indigo-400 hover:text-indigo-300 hover:underline font-semibold">Clear Filters</button>
        </div>

        <!-- Cards Container -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6" id="workflows-grid">
          {workflows.map(item => (
            <article 
              class="workflow-card glass-card rounded-2xl p-6 flex flex-col justify-between group"
              data-title={item.data.title.toLowerCase()}
              data-description={item.data.description.toLowerCase()}
              data-tool={item.data.primaryTool}
              data-category={item.data.category}
              data-persona={item.data.persona}
            >
              <div>
                <!-- Metadata header badges -->
                <div class="flex justify-between items-center mb-4">
                  <span class="px-2.5 py-0.5 bg-indigo-500/10 border border-indigo-500/20 text-indigo-300 text-xs font-semibold rounded-md">
                    {item.data.primaryTool}
                  </span>
                  <span class="text-xs text-emerald-400 font-medium">
                    ⏱️ {item.data.timeSaved} saved
                  </span>
                </div>

                <!-- Title -->
                <h3 class="text-lg font-bold text-white mb-2 group-hover:text-indigo-400 transition-colors">
                  <a href={`/workflows/${item.id}`}>{item.data.title}</a>
                </h3>

                <!-- Description -->
                <p class="text-xs text-gray-400 leading-relaxed mb-6 line-clamp-3">
                  {item.data.description}
                </p>
              </div>

              <!-- Footer values -->
              <div class="pt-4 border-t border-gray-800/80 flex items-center justify-between">
                <span class="text-[11px] text-gray-500 font-medium">
                  💰 Run cost: {item.data.costToRun}
                </span>
                <a href={`/workflows/${item.id}`} class="text-xs font-bold text-white group-hover:text-indigo-400 flex items-center gap-1 transition-colors">
                  Get Blueprint &rarr;
                </a>
              </div>
            </article>
          ))}

          <!-- No Results State -->
          <div id="no-results" class="hidden col-span-2 py-20 text-center glass-panel rounded-2xl border border-dashed border-gray-800">
            <p class="text-lg text-gray-400 font-semibold mb-2">No workflows found matching your criteria</p>
            <p class="text-sm text-gray-600">Try broadening your search term or adjusting filters.</p>
          </div>
        </div>
      </main>
    </div>
  </div>

  <!-- Client side logic to perform instant, hardware-accelerated searches & filters -->
  <script>
    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    const toolRadios = document.querySelectorAll('input[name="tool-filter"]');
    const categoryRadios = document.querySelectorAll('input[name="category-filter"]');
    const personaRadios = document.querySelectorAll('input[name="persona-filter"]');
    const clearBtn = document.getElementById('clear-filters') as HTMLButtonElement;
    const resultsCountEl = document.getElementById('results-count') as HTMLSpanElement;
    const noResultsEl = document.getElementById('no-results') as HTMLDivElement;
    const cards = document.querySelectorAll('.workflow-card') as NodeListOf<HTMLElement>;

    // Read initial URL params (e.g. ?category=Sales&search=linkedin)
    const urlParams = new URLSearchParams(window.location.search);
    const initialSearch = urlParams.get('search') || '';
    const initialCategory = urlParams.get('category') || '';
    const initialTool = urlParams.get('tool') || '';
    const initialPersona = urlParams.get('persona') || '';

    // Apply URL params to elements
    if (initialSearch && searchInput) searchInput.value = initialSearch;
    if (initialCategory) setRadioValue('category-filter', initialCategory);
    if (initialTool) setRadioValue('tool-filter', initialTool);
    if (initialPersona) setRadioValue('persona-filter', initialPersona);

    function setRadioValue(name: string, value: string) {
      const radio = document.querySelector(`input[name="${name}"][value="${value}"]`) as HTMLInputElement;
      if (radio) radio.checked = true;
    }

    function getRadioValue(name: string): string {
      const radio = document.querySelector(`input[name="${name}"]:checked`) as HTMLInputElement;
      return radio ? radio.value : 'all';
    }

    function filterWorkflows() {
      const query = searchInput ? searchInput.value.toLowerCase().trim() : '';
      const selectedTool = getRadioValue('tool-filter');
      const selectedCategory = getRadioValue('category-filter');
      const selectedPersona = getRadioValue('persona-filter');

      let visibleCount = 0;

      cards.forEach(card => {
        const title = card.getAttribute('data-title') || '';
        const description = card.getAttribute('data-description') || '';
        const tool = card.getAttribute('data-tool') || '';
        const category = card.getAttribute('data-category') || '';
        const persona = card.getAttribute('data-persona') || '';

        const matchesQuery = !query || title.includes(query) || description.includes(query);
        const matchesTool = selectedTool === 'all' || tool === selectedTool;
        const matchesCategory = selectedCategory === 'all' || category === selectedCategory;
        const matchesPersona = selectedPersona === 'all' || persona === selectedPersona;

        if (matchesQuery && matchesTool && matchesCategory && matchesPersona) {
          card.classList.remove('hidden');
          visibleCount++;
        } else {
          card.classList.add('hidden');
        }
      });

      // Update counter
      resultsCountEl.textContent = `Showing ${visibleCount} workflow${visibleCount === 1 ? '' : 's'}`;

      // Toggle no results state
      if (visibleCount === 0) {
        noResultsEl.classList.remove('hidden');
      } else {
        noResultsEl.classList.add('hidden');
      }

      // Show/hide Clear button
      const hasActiveFilters = query !== '' || selectedTool !== 'all' || selectedCategory !== 'all' || selectedPersona !== 'all';
      if (hasActiveFilters) {
        clearBtn.classList.remove('hidden');
      } else {
        clearBtn.classList.add('hidden');
      }
    }

    // Bind event listeners
    if (searchInput) searchInput.addEventListener('input', filterWorkflows);
    toolRadios.forEach(radio => radio.addEventListener('change', filterWorkflows));
    categoryRadios.forEach(radio => radio.addEventListener('change', filterWorkflows));
    personaRadios.forEach(radio => radio.addEventListener('change', filterWorkflows));

    if (clearBtn) {
      clearBtn.addEventListener('click', () => {
        if (searchInput) searchInput.value = '';
        setRadioValue('tool-filter', 'all');
        setRadioValue('category-filter', 'all');
        setRadioValue('persona-filter', 'all');
        filterWorkflows();
      });
    }

    // Initial run
    filterWorkflows();
  </script>
</Layout>
