---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const workflows = await getCollection('workflows');

const categories = [...new Set(workflows.map(w => w.data.category))];
const tools = [...new Set(workflows.map(w => w.data.primaryTool))];
const personas = [...new Set(workflows.map(w => w.data.persona))];
---

<Layout 
  title="AI Automation Workflow Library & Recipes - WorkFlowAI" 
  description="Browse our complete list of verified automation blueprints, JSON configurations, and prompt scripts for n8n, Make.com, and Claude."
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    <!-- Page Header -->
    <div class="mb-10">
      <p class="text-[11px] font-bold text-indigo-400 uppercase tracking-widest mb-3">Library</p>
      <h1 class="font-display text-3xl md:text-5xl font-extrabold text-white mb-3 tracking-tight">
        Automation Blueprints
      </h1>
      <p class="text-gray-500 text-base max-w-2xl">
        Filter by department, primary automation tool, or search for specific integrations to find your recipe.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
      
      <!-- ============================================================
           FILTERS SIDEBAR
           ============================================================ -->
      <aside class="col-span-1 space-y-4" aria-label="Filter workflows">

        <!-- Search Widget -->
        <div class="glass-panel p-5 rounded-2xl border border-white/5">
          <h2 class="text-[10px] font-bold text-gray-600 uppercase tracking-widest mb-3">Search</h2>
          <div class="relative">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 h-3.5 w-3.5 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input 
              type="text" 
              id="search-input" 
              placeholder="Filter blueprints..." 
              class="w-full bg-[#0B0F19] border border-white/5 rounded-xl pl-9 pr-4 py-2.5 text-xs text-white placeholder-gray-600 focus:outline-none focus:border-indigo-500/40 transition-colors"
              aria-label="Search workflows"
            />
          </div>
        </div>

        <!-- Tool Filter -->
        <div class="glass-panel p-5 rounded-2xl border border-white/5">
          <h2 class="text-[10px] font-bold text-gray-600 uppercase tracking-widest mb-4">Automation Tool</h2>
          <div class="space-y-3">
            <label class="flex items-center gap-3 text-xs text-gray-500 hover:text-white cursor-pointer select-none group">
              <input type="radio" name="tool-filter" value="all" checked class="accent-indigo-500 w-3.5 h-3.5 flex-shrink-0" />
              <span class="group-hover:text-gray-200 transition-colors">All Tools</span>
            </label>
            {tools.map(tool => (
              <label class="flex items-center gap-3 text-xs text-gray-500 hover:text-white cursor-pointer select-none group">
                <input type="radio" name="tool-filter" value={tool} class="accent-indigo-500 w-3.5 h-3.5 flex-shrink-0" />
                <span class="group-hover:text-gray-200 transition-colors">{tool}</span>
              </label>
            ))}
          </div>
        </div>

        <!-- Category Filter -->
        <div class="glass-panel p-5 rounded-2xl border border-white/5">
          <h2 class="text-[10px] font-bold text-gray-600 uppercase tracking-widest mb-4">Department</h2>
          <div class="space-y-3">
            <label class="flex items-center gap-3 text-xs text-gray-500 hover:text-white cursor-pointer select-none group">
              <input type="radio" name="category-filter" value="all" checked class="accent-indigo-500 w-3.5 h-3.5 flex-shrink-0" />
              <span class="group-hover:text-gray-200 transition-colors">All Categories</span>
            </label>
            {categories.map(cat => (
              <label class="flex items-center gap-3 text-xs text-gray-500 hover:text-white cursor-pointer select-none group">
                <input type="radio" name="category-filter" value={cat} class="accent-indigo-500 w-3.5 h-3.5 flex-shrink-0" />
                <span class="group-hover:text-gray-200 transition-colors">{cat}</span>
              </label>
            ))}
          </div>
        </div>

        <!-- Persona Filter -->
        <div class="glass-panel p-5 rounded-2xl border border-white/5">
          <h2 class="text-[10px] font-bold text-gray-600 uppercase tracking-widest mb-4">Target Role</h2>
          <div class="space-y-3">
            <label class="flex items-center gap-3 text-xs text-gray-500 hover:text-white cursor-pointer select-none group">
              <input type="radio" name="persona-filter" value="all" checked class="accent-indigo-500 w-3.5 h-3.5 flex-shrink-0" />
              <span class="group-hover:text-gray-200 transition-colors">All Roles</span>
            </label>
            {personas.map(pers => (
              <label class="flex items-center gap-3 text-xs text-gray-500 hover:text-white cursor-pointer select-none group">
                <input type="radio" name="persona-filter" value={pers} class="accent-indigo-500 w-3.5 h-3.5 flex-shrink-0" />
                <span class="group-hover:text-gray-200 transition-colors">For {pers}</span>
              </label>
            ))}
          </div>
        </div>

        <!-- CTA sidebar card -->
        <div class="relative glass-panel rounded-2xl p-5 border border-indigo-500/10 overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-br from-indigo-950/40 to-transparent pointer-events-none"></div>
          <div class="relative z-10">
            <p class="text-xs font-bold text-white mb-1.5">Have a workflow?</p>
            <p class="text-[11px] text-gray-500 mb-4 leading-relaxed">Share it with the community and help others save time.</p>
            <a href="/submit" class="btn btn-primary text-[11px] w-full justify-center py-2.5">
              Submit Recipe →
            </a>
          </div>
        </div>
      </aside>

      <!-- ============================================================
           WORKFLOWS GRID
           ============================================================ -->
      <main class="col-span-1 lg:col-span-3" aria-label="Workflow results">
        <!-- Results toolbar -->
        <div class="flex justify-between items-center mb-5 h-8">
          <span id="results-count" class="text-xs text-gray-600 font-semibold">
            Showing {workflows.length} workflows
          </span>
          <button 
            id="clear-filters" 
            class="hidden text-xs text-indigo-400 hover:text-indigo-300 font-bold transition-colors"
            aria-label="Clear all filters"
          >
            Clear Filters ✕
          </button>
        </div>

        <!-- Cards Container -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5" id="workflows-grid">
          {workflows.map(item => {
            const difficultyClass = 
              item.data.difficulty === 'Beginner' ? 'difficulty-beginner' :
              item.data.difficulty === 'Advanced' ? 'difficulty-advanced' :
              'difficulty-intermediate';

            return (
              <article 
                class="workflow-card glass-card rounded-2xl p-6 flex flex-col justify-between group"
                data-title={item.data.title.toLowerCase()}
                data-description={item.data.description.toLowerCase()}
                data-tool={item.data.primaryTool}
                data-category={item.data.category}
                data-persona={item.data.persona}
              >
                <div>
                  <!-- Badge row -->
                  <div class="flex justify-between items-center mb-4">
                    <span class="badge badge-indigo">
                      {item.data.primaryTool}
                    </span>
                    <span class={`badge ${difficultyClass}`}>
                      {item.data.difficulty}
                    </span>
                  </div>

                  <!-- Title -->
                  <h3 class="text-base font-bold text-white mb-2.5 group-hover:text-indigo-300 transition-colors leading-snug">
                    <a 
                      href={`/workflows/${item.id}`}
                      class="focus:outline-none focus:text-indigo-400"
                    >
                      {item.data.title}
                    </a>
                  </h3>

                  <!-- Description -->
                  <p class="text-sm text-gray-500 leading-relaxed mb-5 line-clamp-3">
                    {item.data.description}
                  </p>
                </div>

                <!-- Footer -->
                <div class="pt-4 border-t border-white/4 flex items-center justify-between">
                  <div class="flex items-center gap-3 text-[11px]">
                    <span class="text-emerald-400/80 font-semibold flex items-center gap-1">
                      <span>⏱</span>
                      {item.data.timeSaved}
                    </span>
                    <span class="text-gray-600">
                      💰 {item.data.costToRun}
                    </span>
                  </div>
                  <a 
                    href={`/workflows/${item.id}`} 
                    class="text-xs font-bold text-indigo-500 hover:text-indigo-300 flex items-center gap-1 transition-colors group-hover:translate-x-0.5 transform"
                    aria-label={`View ${item.data.title} blueprint`}
                  >
                    Get Blueprint →
                  </a>
                </div>
              </article>
            );
          })}

          <!-- No Results State -->
          <div 
            id="no-results" 
            class="hidden col-span-2 py-20 text-center glass-panel rounded-2xl border border-dashed border-white/8"
            role="status"
            aria-live="polite"
          >
            <div class="text-4xl mb-4">🔍</div>
            <p class="text-base text-gray-400 font-bold mb-2">No workflows match your filters</p>
            <p class="text-sm text-gray-600 mb-5">Try broadening your search or adjusting the filters.</p>
            <button id="clear-filters-empty" class="btn btn-secondary text-xs px-5 py-2.5">
              Clear All Filters
            </button>
          </div>
        </div>
      </main>
    </div>
  </div>

  <script>
    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    const toolRadios = document.querySelectorAll('input[name="tool-filter"]');
    const categoryRadios = document.querySelectorAll('input[name="category-filter"]');
    const personaRadios = document.querySelectorAll('input[name="persona-filter"]');
    const clearBtn = document.getElementById('clear-filters') as HTMLButtonElement;
    const clearBtnEmpty = document.getElementById('clear-filters-empty') as HTMLButtonElement;
    const resultsCountEl = document.getElementById('results-count') as HTMLSpanElement;
    const noResultsEl = document.getElementById('no-results') as HTMLDivElement;
    const cards = document.querySelectorAll('.workflow-card') as NodeListOf<HTMLElement>;

    // Initialize from URL params
    const urlParams = new URLSearchParams(window.location.search);
    const initialSearch = urlParams.get('search') || '';
    const initialCategory = urlParams.get('category') || '';
    const initialTool = urlParams.get('tool') || '';
    const initialPersona = urlParams.get('persona') || '';

    if (initialSearch && searchInput) searchInput.value = initialSearch;
    if (initialCategory) setRadioValue('category-filter', initialCategory);
    if (initialTool) setRadioValue('tool-filter', initialTool);
    if (initialPersona) setRadioValue('persona-filter', initialPersona);

    function setRadioValue(name: string, value: string) {
      const radio = document.querySelector(`input[name="${name}"][value="${value}"]`) as HTMLInputElement;
      if (radio) radio.checked = true;
    }

    function getRadioValue(name: string): string {
      const radio = document.querySelector(`input[name="${name}"]:checked`) as HTMLInputElement;
      return radio ? radio.value : 'all';
    }

    function filterWorkflows() {
      const query = searchInput ? searchInput.value.toLowerCase().trim() : '';
      const selectedTool = getRadioValue('tool-filter');
      const selectedCategory = getRadioValue('category-filter');
      const selectedPersona = getRadioValue('persona-filter');

      let visibleCount = 0;

      cards.forEach(card => {
        const title = card.getAttribute('data-title') || '';
        const description = card.getAttribute('data-description') || '';
        const tool = card.getAttribute('data-tool') || '';
        const category = card.getAttribute('data-category') || '';
        const persona = card.getAttribute('data-persona') || '';

        const matchesQuery = !query || title.includes(query) || description.includes(query);
        const matchesTool = selectedTool === 'all' || tool === selectedTool;
        const matchesCategory = selectedCategory === 'all' || category === selectedCategory;
        const matchesPersona = selectedPersona === 'all' || persona === selectedPersona;

        const visible = matchesQuery && matchesTool && matchesCategory && matchesPersona;
        card.classList.toggle('hidden', !visible);
        if (visible) visibleCount++;
      });

      resultsCountEl.textContent = `Showing ${visibleCount} workflow${visibleCount === 1 ? '' : 's'}`;
      noResultsEl.classList.toggle('hidden', visibleCount > 0);

      const hasActiveFilters = query !== '' || selectedTool !== 'all' || selectedCategory !== 'all' || selectedPersona !== 'all';
      clearBtn.classList.toggle('hidden', !hasActiveFilters);
    }

    function clearAllFilters() {
      if (searchInput) searchInput.value = '';
      setRadioValue('tool-filter', 'all');
      setRadioValue('category-filter', 'all');
      setRadioValue('persona-filter', 'all');
      filterWorkflows();
    }

    if (searchInput) searchInput.addEventListener('input', filterWorkflows);
    toolRadios.forEach(r => r.addEventListener('change', filterWorkflows));
    categoryRadios.forEach(r => r.addEventListener('change', filterWorkflows));
    personaRadios.forEach(r => r.addEventListener('change', filterWorkflows));
    if (clearBtn) clearBtn.addEventListener('click', clearAllFilters);
    if (clearBtnEmpty) clearBtnEmpty.addEventListener('click', clearAllFilters);

    // Run on page load
    filterWorkflows();
  </script>
</Layout>
