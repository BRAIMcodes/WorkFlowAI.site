---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const workflows = await getCollection('workflows');
const featuredWorkflows = workflows.slice(0, 3);

const categoriesList = [
  { name: 'Sales', icon: '💰', desc: 'Lead qualification, CRM synchronization, and outreach hooks.' },
  { name: 'Marketing', icon: '📢', desc: 'YouTube transcript summaries, blog writing, and social campaigns.' },
  { name: 'Recruiting', icon: '🤝', desc: 'Resume screening, candidate pipelines, and outreach drafts.' },
  { name: 'Customer Support', icon: '💬', desc: 'Urgency triage, outage alerts, and auto-reply drafts.' },
  { name: 'Operations', icon: '⚙️', desc: 'Process automations, cross-app sync, and data audits.' }
];

const uniqueTools = [...new Set(workflows.map(w => w.data.primaryTool))];
const uniquePersonas = [...new Set(workflows.map(w => w.data.persona))];
---

<Layout title="WorkFlowAI - Download AI Automation Blueprints & JSON Recipes">
  <!-- Glowing Background Effects -->
  <div class="relative overflow-hidden pt-16 pb-28 md:pt-28 md:pb-36">
    <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] rounded-full bg-indigo-600/5 blur-[120px] pointer-events-none"></div>
    <div class="absolute bottom-[-5%] right-[-5%] w-[600px] h-[600px] rounded-full bg-violet-600/5 blur-[130px] pointer-events-none"></div>

    <!-- Hero Content -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
      <div class="inline-flex items-center gap-2 px-3 py-1 bg-indigo-950/40 border border-indigo-500/20 rounded-full text-indigo-300 text-xs font-semibold tracking-wide uppercase mb-6">
        🚀 The Wikipedia of AI Workflows
      </div>
      
      <h1 class="text-4xl sm:text-6xl md:text-7xl font-extrabold tracking-tight text-white mb-6 leading-none max-w-4xl mx-auto">
        Stop building automations <br />
        <span class="text-gradient">from scratch.</span>
      </h1>
      
      <p class="max-w-xl mx-auto text-base sm:text-lg text-gray-400 mb-10 leading-relaxed">
        Download verified, production-ready AI workflows, copy system prompts, and get Make.com blueprints or n8n JSON files for free.
      </p>

      <!-- Raycast-Style Command Search Bar -->
      <div class="max-w-2xl mx-auto mb-20">
        <form action="/workflows" method="GET" class="relative flex items-center bg-gray-900/60 backdrop-blur-md border border-gray-800/80 p-1.5 rounded-2xl shadow-2xl shadow-indigo-500/5 focus-within:border-indigo-500/60 focus-within:shadow-indigo-500/10 transition-all duration-300">
          <span class="pl-4 text-gray-500 shrink-0">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </span>
          <input 
            type="text" 
            name="search" 
            placeholder="Search e.g., 'Lead Qualification' or 'n8n'..." 
            class="w-full bg-transparent text-white border-0 focus:ring-0 outline-none px-4 py-3 text-sm placeholder-gray-500" 
          />
          <button type="submit" class="px-5 py-2.5 bg-indigo-600 hover:bg-indigo-550 text-white text-xs font-bold rounded-xl transition-all shadow-md shadow-indigo-600/20 btn-scale shrink-0">
            Find Recipe
          </button>
        </form>
      </div>
    </div>

    <!-- Category Grid Section -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-28 relative z-10">
      <div class="text-center md:text-left mb-10">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-2">Browse by Automation Focus</h2>
        <p class="text-sm text-gray-400">Tactical AI recipes structured to solve specific department bottlenecks.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6">
        {categoriesList.map(cat => (
          <a href={`/workflows?category=${cat.name}`} class="glass-card rounded-2xl p-6 flex flex-col justify-between text-left group">
            <div>
              <div class="w-12 h-12 bg-indigo-950/40 border border-indigo-500/10 rounded-xl flex items-center justify-center text-xl mb-4 group-hover:bg-indigo-600 group-hover:border-indigo-500 group-hover:text-white transition-all duration-300">
                {cat.icon}
              </div>
              <h3 class="text-md font-bold text-white mb-2 group-hover:text-indigo-400 transition-colors">
                {cat.name}
              </h3>
              <p class="text-xs text-gray-400 leading-relaxed line-clamp-3">
                {cat.desc}
              </p>
            </div>
            <span class="text-xs text-indigo-400 font-bold group-hover:text-indigo-300 mt-4 flex items-center gap-1 transition-colors">
              Explore {cat.name} &rarr;
            </span>
          </a>
        ))}
      </div>
    </section>

    <!-- Trending Blueprints Section -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-28 relative z-10">
      <div class="flex flex-col sm:flex-row sm:justify-between sm:items-end mb-10 gap-4">
        <div>
          <h2 class="text-2xl md:text-3xl font-bold text-white mb-2">Trending AI Blueprints</h2>
          <p class="text-sm text-gray-400">Tested, ready-to-run automation structures with downloadable JSON assets.</p>
        </div>
        <a href="/workflows" class="inline-flex items-center gap-2 text-indigo-400 hover:text-indigo-300 font-semibold text-xs group transition-colors">
          Explore all workflows
          <span class="group-hover:translate-x-1 transition-transform">&rarr;</span>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {featuredWorkflows.map(item => (
          <article class="glass-card rounded-2xl p-6 flex flex-col justify-between group">
            <div>
              <!-- Tool Tag & Metric -->
              <div class="flex justify-between items-center mb-4">
                <span class="px-2.5 py-0.5 bg-indigo-950/40 border border-indigo-500/20 text-indigo-300 text-[11px] font-semibold rounded-md">
                  ⚙️ {item.data.primaryTool}
                </span>
                <span class="text-xs text-emerald-400 font-medium">
                  ⏱️ {item.data.timeSaved} saved
                </span>
              </div>

              <!-- Title -->
              <h3 class="text-lg font-bold text-white mb-2 group-hover:text-indigo-400 transition-colors line-clamp-1">
                <a href={`/workflows/${item.id}`}>{item.data.title}</a>
              </h3>

              <!-- Description -->
              <p class="text-sm text-gray-400 leading-relaxed mb-6 line-clamp-2">
                {item.data.description}
              </p>
            </div>

            <!-- Footer Meta & CTA -->
            <div class="pt-4 border-t border-slate-800/60 flex items-center justify-between">
              <span class="text-[11px] text-gray-500 font-medium">
                💰 Run cost: {item.data.costToRun}
              </span>
              <a href={`/workflows/${item.id}`} class="text-xs font-bold text-white group-hover:text-indigo-400 flex items-center gap-1 transition-colors">
                Get Recipe
                <span class="group-hover:translate-x-0.5 transition-transform">&rarr;</span>
              </a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- Programmatic SEO Hub Intersections -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="glass-panel rounded-3xl p-8 md:p-12 relative overflow-hidden border border-gray-800/80">
        <div class="absolute top-0 right-0 w-80 h-80 bg-indigo-600/5 blur-[80px] pointer-events-none"></div>
        
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 items-center">
          <div class="col-span-1 lg:col-span-1">
            <h2 class="text-xl md:text-2xl font-bold text-white mb-3">
              Integrated Platforms & Roles
            </h2>
            <p class="text-gray-400 text-sm leading-relaxed">
              We compile integrations programmatically. Click below to view all blueprints filtered by specific platforms or target departments.
            </p>
          </div>

          <div class="col-span-1 lg:col-span-2 space-y-6">
            <div>
              <h4 class="text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-3">AI & Automation Tools</h4>
              <div class="flex flex-wrap gap-2">
                {uniqueTools.map(tool => (
                  <a href={`/tools/${tool.toLowerCase().replace(/\s+/g, '-')}`} class="px-3.5 py-1.5 bg-slate-900/60 hover:bg-slate-900 border border-slate-800/80 hover:border-slate-700 text-xs font-semibold rounded-xl text-gray-300 hover:text-white transition-all">
                    {tool} Recipes
                  </a>
                ))}
              </div>
            </div>

            <div>
              <h4 class="text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-3">Target Roles</h4>
              <div class="flex flex-wrap gap-2">
                {uniquePersonas.map(persona => (
                  <a href={`/personas/${persona.toLowerCase().replace(/\s+/g, '-')}`} class="px-3.5 py-1.5 bg-slate-900/60 hover:bg-slate-900 border border-slate-800/80 hover:border-slate-700 text-xs font-semibold rounded-xl text-gray-300 hover:text-white transition-all">
                    For {persona}
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>
