---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="404 — Page Not Found | WorkFlowAI"
  description="This page doesn't exist. Browse our library of AI workflow blueprints and automation recipes."
>
  <div class="relative overflow-hidden min-h-[70vh] flex items-center justify-center">
    <!-- Ambient glow -->
    <div class="glow-orb glow-orb-indigo" style="width:500px;height:500px;top:0;left:50%;transform:translateX(-50%);opacity:0.5;"></div>

    <div class="relative z-10 text-center max-w-lg mx-auto px-4 py-20">
      <!-- Error code -->
      <div class="font-display text-[120px] sm:text-[160px] font-extrabold leading-none text-gradient opacity-20 select-none mb-0" aria-hidden="true">
        404
      </div>

      <div class="-mt-4 mb-8">
        <h1 class="font-display text-2xl sm:text-3xl font-bold text-white mb-3">
          This page doesn't exist
        </h1>
        <p class="text-gray-500 text-base leading-relaxed">
          The recipe you're looking for has moved or was never here. 
          Browse the full library instead.
        </p>
      </div>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="/workflows" class="btn btn-primary px-6 py-3">
          Browse Workflows
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
        <a href="/" class="btn btn-ghost border border-white/8 px-6 py-3">
          Go Home
        </a>
      </div>

      <!-- Quick links -->
      <div class="mt-12 pt-8 border-t border-white/5">
        <p class="text-xs text-gray-500 uppercase tracking-widest font-semibold mb-4">Popular Pages</p>
        <div class="flex flex-wrap justify-center gap-2">
          {[
            { href: '/tools', label: 'Tools Catalog' },
            { href: '/personas', label: 'By Role' },
            { href: '/submit', label: 'Submit a Recipe' },
            { href: '/about', label: 'About' },
          ].map(link => (
            <a 
              href={link.href}
              class="px-3 py-1.5 bg-white/4 hover:bg-white/8 border border-white/6 hover:border-white/10 rounded-full text-xs text-gray-400 hover:text-gray-200 transition-all"
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</Layout>
