---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
---

<Layout title="Careers at WorkFlowAI" description="Join the WorkFlowAI team. Help us empower professionals to automate their businesses with AI.">
  <div class="relative overflow-hidden pt-12 pb-24 text-center">
    <!-- Glowing background effects -->
    <div class="glow-orb glow-orb-indigo" style="top:-10%;left:-10%"></div>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="mb-12">
        <span class="px-4 py-1.5 bg-indigo-500/10 border border-indigo-500/20 rounded-full text-indigo-300 text-[11px] font-semibold tracking-widest uppercase">
          <Icon name="zap" class="w-3.5 h-3.5" /> Join Our Team
        </span>
        <h1 class="font-display text-4xl sm:text-6xl font-extrabold text-white mt-6 mb-6 leading-tight">
          Build the Future of <span class="text-gradient">Work</span>
        </h1>
        <p class="text-lg text-gray-400 max-w-2xl mx-auto leading-relaxed">
          We are looking for builders, writers, and automators who are obsessed with efficiency and want to share practical AI knowledge with millions of operators.
        </p>
      </div>

      <div class="max-w-xl mx-auto glass-panel border border-white/6 rounded-3xl p-8 mt-12 text-center">
        <h3 class="text-xl font-bold text-white mb-2">No Open Positions Currently</h3>
        <p class="text-sm text-gray-500 mb-6">We just filled our latest round of engineering and content roles. However, we are always on the lookout for talented creators.</p>
        <a href="mailto:careers@workflowai.site" class="inline-flex justify-center items-center px-6 py-3.5 bg-gray-900 hover:bg-gray-800 border border-white/6 text-white font-bold rounded-xl transition-all shadow-md">
          Send Us Your Resume
        </a>
      </div>
    </div>
  </div>
</Layout>
