---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
---

<Layout title="Contact WorkFlowAI - Get in Touch" description="Contact the WorkFlowAI team for blueprint submissions, feedback, and support inquiries.">
  <div class="relative overflow-hidden pt-12 pb-24">
    <!-- Glowing background effects -->
    <div class="glow-orb glow-orb-violet" style="top:-10%;right:-10%"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 relative z-10">
      <div class="max-w-2xl mx-auto text-center mb-12">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-indigo-500/10 border border-indigo-500/20 rounded-full text-indigo-300 text-[11px] font-semibold tracking-widest uppercase mb-4">
          <Icon name="message-circle" class="w-3.5 h-3.5" /> Get in Touch
        </div>
        <h1 class="font-display text-3xl md:text-5xl font-extrabold text-white mb-4">Contact Our Team</h1>
        <p class="text-gray-500 text-lg">Have a specific automation request or want to submit a recipe? Shoot us a message.</p>
      </div>

      <div class="max-w-xl mx-auto glass-panel rounded-3xl p-8 border border-white/6">
        <form class="space-y-6">
          <div>
            <label for="name" class="block text-sm font-semibold text-gray-300 mb-2">Name</label>
            <input 
              type="text" 
              id="name" 
              name="name" 
              class="w-full bg-[#0B0F19] border border-white/6 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-indigo-500/80 transition-colors" 
              placeholder="Your Name"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-semibold text-gray-300 mb-2">Email</label>
            <input 
              type="email" 
              id="email" 
              name="email" 
              class="w-full bg-[#0B0F19] border border-white/6 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-indigo-500/80 transition-colors" 
              placeholder="you@company.com"
            />
          </div>
          <div>
            <label for="message" class="block text-sm font-semibold text-gray-300 mb-2">Message</label>
            <textarea 
              id="message" 
              name="message" 
              rows="4" 
              class="w-full bg-[#0B0F19] border border-white/6 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-indigo-500/80 transition-colors" 
              placeholder="Describe your automation goals..."
            ></textarea>
          </div>
          <button 
            type="button" 
            onclick="alert('Thank you! This is a demo form. Please email us directly at hello@workflowai.site')" 
            class="btn btn-primary w-full justify-center py-4"
          >
            Send Message
          </button>
        </form>

        <div class="mt-8 pt-8 border-t border-white/6 text-center text-sm text-gray-500">
          <p>Or email us directly at <a href="mailto:hello@workflowai.site" class="text-indigo-400 hover:underline">hello@workflowai.site</a></p>
        </div>
      </div>
    </div>
  </div>
</Layout>
