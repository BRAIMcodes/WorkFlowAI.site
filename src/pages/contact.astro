---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
---

<Layout title="Contact WorkFlowAI - Get in Touch" description="Contact the WorkFlowAI team for blueprint submissions, feedback, and support inquiries.">
  <div class="relative overflow-hidden pt-12 pb-24">
    <!-- Glowing background effects -->
    <div class="glow-orb glow-orb-violet" style="top:-10%;right:-10%"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 relative z-10">
      <div class="max-w-2xl mx-auto text-center mb-12">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-indigo-500/10 border border-indigo-500/20 rounded-full text-indigo-300 text-[11px] font-semibold tracking-widest uppercase mb-4">
          <Icon name="message-circle" class="w-3.5 h-3.5" /> Get in Touch
        </div>
        <h1 class="font-display text-3xl md:text-5xl font-extrabold text-white mb-4">Contact Our Team</h1>
        <p class="text-gray-500 text-lg">Have a specific automation request or want to submit a recipe? Shoot us a message.</p>
      </div>

      <div class="max-w-xl mx-auto glass-panel rounded-3xl p-8 border border-white/6">
        <form id="contact-form" class="space-y-6">
          <div>
            <label for="name" class="block text-sm font-semibold text-gray-300 mb-2">Name</label>
            <input 
              type="text" 
              id="name" 
              name="name" 
              class="w-full bg-[#0B0F19] border border-white/6 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-indigo-500/80 transition-colors" 
              placeholder="Your Name"
              required
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-semibold text-gray-300 mb-2">Email</label>
            <input 
              type="email" 
              id="email" 
              name="email" 
              class="w-full bg-[#0B0F19] border border-white/6 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-indigo-500/80 transition-colors" 
              placeholder="you@company.com"
              required
            />
          </div>
          <div>
            <label for="message" class="block text-sm font-semibold text-gray-300 mb-2">Message</label>
            <textarea 
              id="message" 
              name="message" 
              rows="4" 
              class="w-full bg-[#0B0F19] border border-white/6 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-indigo-500/80 transition-colors" 
              placeholder="Describe your automation goals..."
              required
            ></textarea>
          </div>
          
          <button 
            type="submit" 
            id="contact-submit-btn" 
            class="btn btn-primary w-full justify-center py-4"
          >
            Send Message
          </button>
          
          <p id="contact-form-message" class="text-center text-xs mt-2 font-medium min-h-[1.25rem]"></p>
        </form>

        <div class="mt-8 pt-8 border-t border-white/6 text-center text-sm text-gray-500">
          <p>Or email us directly at <a href="mailto:hello@workflowai.site" class="text-indigo-400 hover:underline">hello@workflowai.site</a></p>
        </div>
      </div>
    </div>
  </div>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const submitBtn = document.getElementById('contact-submit-btn') as HTMLButtonElement;
    const messageEl = document.getElementById('contact-form-message');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!submitBtn || !messageEl) return;

      const originalText = submitBtn.textContent;
      submitBtn.textContent = 'Sending Message...';
      submitBtn.disabled = true;
      submitBtn.style.opacity = '0.7';
      messageEl.textContent = '';
      messageEl.className = 'text-center text-xs mt-2 font-medium min-h-[1.25rem]';

      const formData = new FormData(form);

      try {
        const response = await fetch('/api/contact', {
          method: 'POST',
          body: formData
        });

        const data = await response.json();

        if (response.ok) {
          messageEl.textContent = "Thank you! Your message was sent successfully.";
          messageEl.className = 'text-center text-xs mt-2 font-medium text-emerald-400';
          form.reset();
        } else {
          messageEl.textContent = data.message || 'Failed to send. Please try again.';
          messageEl.className = 'text-center text-xs mt-2 font-medium text-red-400';
        }
      } catch (err) {
        messageEl.textContent = 'Connection error. Please try again or email us directly.';
        messageEl.className = 'text-center text-xs mt-2 font-medium text-red-400';
      } finally {
        submitBtn.textContent = originalText;
        submitBtn.disabled = false;
        submitBtn.style.opacity = '1';
      }
    });
  </script>
</Layout>
