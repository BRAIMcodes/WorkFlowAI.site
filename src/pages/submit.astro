---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
---

<Layout 
  title="Submit a Workflow Blueprint - WorkFlowAI" 
  description="Contribute to the AI automation library. Share your n8n JSON configs, Make.com blueprints, or system prompts."
>
  <div class="relative overflow-hidden pt-14 pb-24">
    <!-- Glow orbs -->
    <div class="glow-orb glow-orb-indigo" style="width:500px;height:500px;top:-150px;left:-150px;opacity:0.7;"></div>
    <div class="glow-orb glow-orb-violet" style="width:400px;height:400px;bottom:0;right:-100px;opacity:0.5;"></div>

    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      
      <!-- Header -->
      <div class="text-center mb-12">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-indigo-500/10 border border-indigo-500/20 rounded-full text-indigo-300 text-[11px] font-semibold uppercase tracking-widest mb-6">
          <Icon name="inbox" class="w-3.5 h-3.5" /> Community Contributions
        </div>
        <h1 class="font-display text-3xl md:text-5xl font-extrabold text-white mb-4 tracking-tight">
          Submit an AI Workflow
        </h1>
        <p class="text-gray-500 text-base max-w-xl mx-auto leading-relaxed">
          Share your recipes with the community. Your blueprint helps someone save hours every week.
        </p>
      </div>

      <!-- Submission Options -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-10">
        
        <!-- GitHub Option -->
        <div class="glass-card rounded-2xl p-6 border border-white/5 flex flex-col justify-between group">
          <div>
            <div class="w-11 h-11 rounded-xl bg-white/5 border border-white/8 flex items-center justify-center mb-5">
              <svg class="w-5 h-5 text-gray-300" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
              </svg>
            </div>
            <div class="badge badge-slate mb-4">Recommended for Developers</div>
            <h2 class="text-base font-bold text-white mb-2.5">Submit via GitHub Issue</h2>
            <p class="text-sm text-gray-500 leading-relaxed">
              Open a pre-formatted GitHub issue. Paste your n8n JSON or Make.com blueprint directly. Gets reviewed within 48 hours.
            </p>
          </div>
          <a 
            href="https://github.com/BRAIMcodes/WorkFlowAI.site/issues/new?title=[Submission]+New+Workflow+Recipe&body=Describe+your+workflow+here..." 
            target="_blank" 
            rel="noopener noreferrer"
            class="btn btn-secondary text-xs mt-6 w-full justify-center"
            aria-label="Submit via GitHub"
          >
            Open GitHub Issue →
          </a>
        </div>

        <!-- Email Option -->
        <div class="glass-card rounded-2xl p-6 border border-indigo-500/15 flex flex-col justify-between group" style="background: linear-gradient(145deg, rgba(99,102,241,0.06) 0%, rgba(11,15,25,0.7) 100%);">
          <div>
            <div class="w-11 h-11 rounded-xl bg-indigo-600/10 border border-indigo-500/20 flex items-center justify-center mb-5">
              <svg class="w-5 h-5 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div class="badge badge-indigo mb-4">No Account Needed</div>
            <h2 class="text-base font-bold text-white mb-2.5">Submit via Email Form</h2>
            <p class="text-sm text-gray-500 leading-relaxed">
              Fill in the form below and we'll compile it into a formatted email draft for you to send with one click.
            </p>
          </div>
          <a 
            href="#form-builder"
            class="btn btn-primary text-xs mt-6 w-full justify-center"
          >
            Use Email Form ↓
          </a>
        </div>
      </div>

      <!-- What happens next -->
      <div class="glass-panel rounded-2xl p-5 border border-white/5 mb-10">
        <h3 class="text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-4">What happens after you submit</h3>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div class="text-center">
            <div class="text-2xl mb-2"><Icon name="search" class="w-5 h-5 text-indigo-400" /></div>
            <p class="text-xs font-bold text-gray-300 mb-1">We review it</p>
            <p class="text-[11px] text-gray-500 leading-relaxed">Our team verifies it works end-to-end within 48–72 hours.</p>
          </div>
          <div class="text-center">
            <div class="text-2xl mb-2"><Icon name="edit" class="w-5 h-5 text-indigo-400" /></div>
            <p class="text-xs font-bold text-gray-300 mb-1">We document it</p>
            <p class="text-[11px] text-gray-500 leading-relaxed">We format it with a proper step guide, metadata, and tags.</p>
          </div>
          <div class="text-center">
            <div class="text-2xl mb-2"><Icon name="rocket" class="w-5 h-5 text-indigo-400" /></div>
            <p class="text-xs font-bold text-gray-300 mb-1">It goes live</p>
            <p class="text-[11px] text-gray-500 leading-relaxed">Your recipe is published and attributed to you in the library.</p>
          </div>
        </div>
      </div>

      <!-- Form Builder -->
      <div id="form-builder" class="glass-panel rounded-2xl p-8 border border-white/5 scroll-mt-24">
        <div class="flex items-center gap-3 mb-7">
          <div class="w-8 h-8 rounded-xl bg-indigo-600/10 border border-indigo-500/20 flex items-center justify-center">
            <svg class="w-4 h-4 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
            </svg>
          </div>
          <div>
            <h2 class="font-display text-base font-bold text-white">Recipe Builder Form</h2>
            <p class="text-[11px] text-gray-500">Fill in the details — we'll format the email for you.</p>
          </div>
        </div>
        
        <form class="space-y-5" novalidate aria-label="Recipe submission form">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div>
              <label for="recipe-title" class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-2">Workflow Title *</label>
              <input 
                type="text" 
                id="recipe-title" 
                placeholder="e.g. Lead Qualification with n8n"
                class="w-full bg-[#0B0F19] border border-white/6 rounded-xl px-4 py-3 text-sm text-white placeholder-gray-500 focus:outline-none transition-all" 
                required
              />
            </div>
            <div>
              <label for="recipe-tool" class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-2">Primary Tool *</label>
              <select 
                id="recipe-tool" 
                class="w-full bg-[#0B0F19] border border-white/6 rounded-xl px-4 py-3 text-sm text-gray-300 focus:outline-none transition-all appearance-none"
                required
              >
                <option value="n8n">n8n</option>
                <option value="Make.com">Make.com</option>
                <option value="Zapier">Zapier</option>
                <option value="LangChain">LangChain</option>
                <option value="Other">Other / Custom Code</option>
              </select>
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div>
              <label for="recipe-apps" class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-2">Connected Apps</label>
              <input 
                type="text" 
                id="recipe-apps" 
                placeholder="e.g. Claude 3.5, HubSpot, Slack"
                class="w-full bg-[#0B0F19] border border-white/6 rounded-xl px-4 py-3 text-sm text-white placeholder-gray-500 focus:outline-none transition-all" 
              />
            </div>
            <div>
              <label for="recipe-saved" class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-2">Time Saved per Week</label>
              <input 
                type="text" 
                id="recipe-saved" 
                placeholder="e.g. 5 hours/week"
                class="w-full bg-[#0B0F19] border border-white/6 rounded-xl px-4 py-3 text-sm text-white placeholder-gray-500 focus:outline-none transition-all" 
              />
            </div>
          </div>

          <div>
            <label for="recipe-desc" class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-2">Description / Pain Point Solved *</label>
            <textarea 
              id="recipe-desc" 
              rows="3"
              placeholder="What manual bottleneck does this resolve and how does it help the user?"
              class="w-full bg-[#0B0F19] border border-white/6 rounded-xl px-4 py-3 text-sm text-white placeholder-gray-500 focus:outline-none transition-all resize-none" 
              required
            ></textarea>
          </div>

          <div>
            <label for="recipe-prompt" class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-2">System AI Prompt <span class="normal-case text-gray-500">(optional)</span></label>
            <textarea 
              id="recipe-prompt" 
              rows="3"
              placeholder="Paste the exact LLM prompt instructions used in this workflow..."
              class="w-full bg-[#0B0F19] border border-white/6 rounded-xl px-4 py-3 text-sm text-white placeholder-gray-500 focus:outline-none transition-all font-mono resize-none"
            ></textarea>
          </div>

          <div>
            <label for="recipe-blueprint" class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-2">Link to JSON / Blueprint File <span class="normal-case text-gray-500">(optional)</span></label>
            <input 
              type="url" 
              id="recipe-blueprint" 
              placeholder="Dropbox, GitHub, or Drive link to download the JSON"
              class="w-full bg-[#0B0F19] border border-white/6 rounded-xl px-4 py-3 text-sm text-white placeholder-gray-500 focus:outline-none transition-all" 
            />
          </div>

          <div class="pt-2">
            <button 
              type="button" 
              id="emailSubmitBtn"
              class="btn btn-primary w-full justify-center py-4 text-sm"
              aria-label="Draft and send email submission"
            >
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              Draft Email Submission
            </button>
            <p class="text-center text-[11px] text-gray-500 mt-3">
              This will open your email client with a pre-filled message to our team.
            </p>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script>
    const emailBtn = document.getElementById('emailSubmitBtn');
    
    if (emailBtn) {
      emailBtn.addEventListener('click', () => {
        const title = (document.getElementById('recipe-title') as HTMLInputElement).value || 'New AI Workflow Submission';
        const tool = (document.getElementById('recipe-tool') as HTMLSelectElement).value;
        const apps = (document.getElementById('recipe-apps') as HTMLInputElement).value || 'None';
        const saved = (document.getElementById('recipe-saved') as HTMLInputElement).value || 'Not specified';
        const desc = (document.getElementById('recipe-desc') as HTMLTextAreaElement).value || 'No description provided.';
        const prompt = (document.getElementById('recipe-prompt') as HTMLTextAreaElement).value || 'None';
        const blueprint = (document.getElementById('recipe-blueprint') as HTMLInputElement).value || 'None';

        const subject = encodeURIComponent(`[WorkflowAI Submission] ${title}`);
        
        const bodyText = `Hello WorkFlowAI Team,

I'd like to submit a new workflow recipe for your library:

WORKFLOW TITLE: ${title}
PRIMARY TOOL: ${tool}
CONNECTED APPS: ${apps}
EST. TIME SAVED: ${saved}

DESCRIPTION / PROBLEM SOLVED:
${desc}

SYSTEM PROMPT (if any):
${prompt}

LINK TO BLUEPRINT FILE:
${blueprint}

---
Submitted via WorkFlowAI.site`;

        const body = encodeURIComponent(bodyText);
        window.location.href = `mailto:hello@workflowai.site?subject=${subject}&body=${body}`;
      });
    }
  </script>
</Layout>
