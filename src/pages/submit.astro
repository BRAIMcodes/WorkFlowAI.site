---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Submit a Workflow Blueprint - WorkFlowAI" description="Contribute to the AI automation library. Share your n8n JSON configs, Make.com blueprints, or system prompts.">
  <div class="relative overflow-hidden pt-12 pb-24">
    <!-- Glowing background effects -->
    <div class="absolute top-[-10%] left-[-10%] w-[500px] h-[500px] rounded-full bg-indigo-500/5 blur-[120px] pointer-events-none"></div>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      
      <!-- Header Section -->
      <div class="text-center mb-12">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-indigo-500/10 border border-indigo-500/30 rounded-full text-indigo-300 text-xs font-semibold uppercase tracking-wider mb-4">
          📥 Open Source Contributions
        </div>
        <h1 class="text-3xl md:text-5xl font-extrabold text-white mb-4">Submit an AI Workflow</h1>
        <p class="text-gray-400 text-lg max-w-2xl mx-auto">
          Share your recipes with the community. You can submit either by opening a pre-formatted GitHub Issue or by emailing us directly.
        </p>
      </div>

      <!-- Submission Choice -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
        <div class="glass-panel p-6 rounded-3xl border border-gray-800 flex flex-col justify-between items-start">
          <div>
            <span class="text-3xl block mb-3">💻</span>
            <h3 class="text-lg font-bold text-white mb-2">Submit via GitHub</h3>
            <p class="text-xs text-gray-400 leading-relaxed mb-6">
              Perfect for developers. Click below to open a pre-formatted issue template in our repository, paste your n8n JSON/Make blueprint, and submit.
            </p>
          </div>
          <a 
            href="https://github.com/BRAIMcodes/WorkFlowAI.site/issues/new?title=[Submission]+New+Workflow+Recipe&body=Describe+your+workflow+here..." 
            target="_blank" 
            class="px-5 py-3 bg-gray-900 hover:bg-gray-850 border border-gray-800 text-white text-xs font-bold rounded-xl transition-all shadow-md"
          >
            Open GitHub Issue &rarr;
          </a>
        </div>

        <div class="glass-panel p-6 rounded-3xl border border-gray-800 flex flex-col justify-between items-start">
          <div>
            <span class="text-3xl block mb-3">✉️</span>
            <h3 class="text-lg font-bold text-white mb-2">Submit via Form / Email</h3>
            <p class="text-xs text-gray-400 leading-relaxed mb-6">
              Use our quick form builder below. It compiles your parameters into a formatted email draft and opens your default mail client with one click.
            </p>
          </div>
          <a 
            href="#form-builder" 
            class="px-5 py-3 bg-indigo-600 hover:bg-indigo-550 text-white text-xs font-bold rounded-xl transition-all shadow-md shadow-indigo-600/10"
          >
            Go to Form Builder &darr;
          </a>
        </div>
      </div>

      <!-- Form Builder Widget -->
      <div id="form-builder" class="glass-panel rounded-3xl p-8 border border-gray-800 scroll-mt-24">
        <h2 class="text-2xl font-bold text-white mb-6">Recipe Builder Form</h2>
        
        <form class="space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="recipe-title" class="block text-xs font-semibold text-gray-300 mb-2">Workflow Title</label>
              <input 
                type="text" 
                id="recipe-title" 
                placeholder="e.g. Lead Qualification with n8n"
                class="w-full bg-gray-950 border border-gray-800 rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:border-indigo-500/80 transition-colors" 
              />
            </div>
            <div>
              <label for="recipe-tool" class="block text-xs font-semibold text-gray-300 mb-2">Primary Automation Tool</label>
              <select 
                id="recipe-tool" 
                class="w-full bg-gray-950 border border-gray-800 rounded-xl px-4 py-3 text-sm text-gray-400 focus:outline-none focus:border-indigo-500/80 transition-colors"
              >
                <option value="n8n">n8n</option>
                <option value="Make.com">Make.com</option>
                <option value="Zapier">Zapier</option>
                <option value="LangChain">LangChain</option>
                <option value="Other">Other / Custom code</option>
              </select>
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="recipe-apps" class="block text-xs font-semibold text-gray-300 mb-2">Connected Apps (Comma Separated)</label>
              <input 
                type="text" 
                id="recipe-apps" 
                placeholder="e.g. Claude 3.5, HubSpot, Slack"
                class="w-full bg-gray-950 border border-gray-800 rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:border-indigo-500/80 transition-colors" 
              />
            </div>
            <div>
              <label for="recipe-saved" class="block text-xs font-semibold text-gray-300 mb-2">Estimated Time Saved per Week</label>
              <input 
                type="text" 
                id="recipe-saved" 
                placeholder="e.g. 5 hours/week"
                class="w-full bg-gray-950 border border-gray-800 rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:border-indigo-500/80 transition-colors" 
              />
            </div>
          </div>

          <div>
            <label for="recipe-desc" class="block text-xs font-semibold text-gray-300 mb-2">Description / Pain Point Solved</label>
            <textarea 
              id="recipe-desc" 
              rows="3"
              placeholder="What manual bottleneck does this resolve and how does it help?"
              class="w-full bg-gray-950 border border-gray-800 rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:border-indigo-500/80 transition-colors" 
            ></textarea>
          </div>

          <div>
            <label for="recipe-prompt" class="block text-xs font-semibold text-gray-300 mb-2">System AI Prompt (Optional)</label>
            <textarea 
              id="recipe-prompt" 
              rows="3"
              placeholder="Paste the exact LLM prompt instructions used in this workflow..."
              class="w-full bg-gray-950 border border-gray-800 rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:border-indigo-500/80 transition-colors" 
            ></textarea>
          </div>

          <div>
            <label for="recipe-blueprint" class="block text-xs font-semibold text-gray-300 mb-2">Link to JSON / Blueprint File (Optional)</label>
            <input 
              type="text" 
              id="recipe-blueprint" 
              placeholder="Dropbox, GitHub, or Drive link to download the JSON"
              class="w-full bg-gray-950 border border-gray-800 rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:border-indigo-500/80 transition-colors" 
            />
          </div>

          <button 
            type="button" 
            id="emailSubmitBtn"
            class="w-full py-4 bg-gradient-to-r from-indigo-600 to-violet-600 hover:from-indigo-500 hover:to-violet-500 text-white font-bold rounded-xl shadow-lg shadow-indigo-600/10 hover:shadow-indigo-500/20 transition-all"
          >
            Draft Email Submission
          </button>
        </form>
      </div>
    </div>
  </div>

  <script>
    const emailBtn = document.getElementById('emailSubmitBtn');
    
    if (emailBtn) {
      emailBtn.addEventListener('click', () => {
        const title = (document.getElementById('recipe-title') as HTMLInputElement).value || 'New AI Workflow Submission';
        const tool = (document.getElementById('recipe-tool') as HTMLSelectElement).value;
        const apps = (document.getElementById('recipe-apps') as HTMLInputElement).value || 'None';
        const saved = (document.getElementById('recipe-saved') as HTMLInputElement).value || 'Not specified';
        const desc = (document.getElementById('recipe-desc') as HTMLTextAreaElement).value || 'No description provided.';
        const prompt = (document.getElementById('recipe-prompt') as HTMLTextAreaElement).value || 'None';
        const blueprint = (document.getElementById('recipe-blueprint') as HTMLInputElement).value || 'None';

        const subject = encodeURIComponent(`[WorkflowAI Submission] ${title}`);
        
        const bodyText = `Hello WorkFlowAI Team,

I'd like to submit a new workflow recipe for your library:

- Title: ${title}
- Primary Tool: ${tool}
- Connected Apps: ${apps}
- Est. Time Saved: ${saved}

Description:
${desc}

System Prompt:
${prompt}

Link to Blueprint File:
${blueprint}

Thank you!`;

        const body = encodeURIComponent(bodyText);
        window.location.href = `mailto:hello@workflowai.site?subject=${subject}&body=${body}`;
      });
    }
  </script>
</Layout>
