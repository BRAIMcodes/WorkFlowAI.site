---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const workflows = await getCollection('workflows');

// Gather all primary tools and connected apps and calculate recipe counts
const toolCounts: Record<string, number> = {};

workflows.forEach(w => {
  const primary = w.data.primaryTool;
  toolCounts[primary] = (toolCounts[primary] || 0) + 1;

  w.data.connectedApps.forEach(app => {
    toolCounts[app] = (toolCounts[app] || 0) + 1;
  });
});

const allTools = Object.keys(toolCounts).sort((a, b) => toolCounts[b] - toolCounts[a]);
---

<Layout title="AI Tools Integration Directory - WorkFlowAI" description="Find automation recipes grouped by specific AI tools and platforms like n8n, Make.com, Claude, ChatGPT, and HubSpot.">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Header Section -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <div class="inline-flex items-center gap-2 px-3 py-1 bg-indigo-500/10 border border-indigo-500/30 rounded-full text-indigo-300 text-xs font-semibold uppercase tracking-wider mb-4">
        🔧 Connectors & Integrations
      </div>
      <h1 class="text-3xl md:text-5xl font-extrabold text-white mb-4">AI Tools Directory</h1>
      <p class="text-gray-400 text-lg">
        Explore pre-built automation recipes grouped by your favorite applications, AI models, and databases.
      </p>
    </div>

    <!-- Grid of Integrated Tools -->
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
      {allTools.map(tool => {
        const slug = tool.toLowerCase().replace(/\s+/g, '-');
        const count = toolCounts[tool];
        return (
          <a href={`/tools/${slug}`} class="glass-card rounded-2xl p-6 flex items-center justify-between group">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-indigo-950 border border-indigo-500/20 text-indigo-300 font-extrabold rounded-xl flex items-center justify-center text-xl group-hover:bg-indigo-600 group-hover:text-white group-hover:border-indigo-500 transition-all duration-300">
                {tool.charAt(0)}
              </div>
              <div>
                <h3 class="font-bold text-white group-hover:text-indigo-400 transition-colors">
                  {tool}
                </h3>
                <span class="text-xs text-gray-500 font-semibold uppercase">
                  {count} recipe{count === 1 ? '' : 's'}
                </span>
              </div>
            </div>
            <span class="text-gray-500 group-hover:text-white transition-colors transform group-hover:translate-x-1 duration-200">
              &rarr;
            </span>
          </a>
        );
      })}
    </div>
  </div>
</Layout>
