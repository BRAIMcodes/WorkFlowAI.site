---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
---

<Layout title="Partnerships - WorkFlowAI" description="Partner with WorkFlowAI to showcase your AI tools or services in front of operations managers and founders.">
  <div class="relative overflow-hidden pt-12 pb-24">
    <!-- Glowing background effects -->
    <div class="glow-orb glow-orb-violet" style="top:-10%;right:-10%"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 relative z-10">
      
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="px-4 py-1.5 bg-indigo-500/10 border border-indigo-500/20 rounded-full text-indigo-300 text-[11px] font-semibold tracking-widest uppercase mb-4 inline-block">
          <Icon name="users" class="w-3.5 h-3.5" /> Work With Us
        </span>
        <h1 class="font-display text-3xl md:text-5xl font-extrabold text-white mb-4">Partner with WorkFlowAI</h1>
        <p class="text-gray-500 text-lg">
          Get your AI tool, SaaS, or automation service in front of active Operations Managers, Solo Founders, and Freelancers who need it.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">
        
        <!-- Feature 1 -->
        <div class="glass-card rounded-3xl p-8 border border-white/6 flex flex-col justify-between group">
           <div>
             <div class="w-12 h-12 bg-indigo-950/40 border border-indigo-500/10 rounded-2xl flex items-center justify-center text-2xl mb-6 group-hover:scale-110 transition-transform">
                <Icon name="rocket" class="w-6 h-6 text-indigo-400" />
             </div>
             <h3 class="text-xl font-bold text-white mb-3">Featured Blueprints</h3>
             <p class="text-sm text-gray-500 leading-relaxed">Let us build a verified recipe using your tool. Users will download your integration configuration directly from our site.</p>
           </div>
        </div>

        <!-- Feature 2 -->
        <div class="glass-card rounded-3xl p-8 border border-white/6 flex flex-col justify-between group">
           <div>
             <div class="w-12 h-12 bg-indigo-950/40 border border-indigo-500/10 rounded-2xl flex items-center justify-center text-2xl mb-6 group-hover:scale-110 transition-transform">
                <Icon name="megaphone" class="w-6 h-6 text-indigo-400" />
             </div>
             <h3 class="text-xl font-bold text-white mb-3">Sponsored Guides</h3>
             <p class="text-sm text-gray-500 leading-relaxed">Deep-dive tutorials, system prompt checklists, and automation case studies written by our operations experts.</p>
           </div>
        </div>

         <!-- Feature 3 -->
        <div class="glass-card rounded-3xl p-8 border border-white/6 flex flex-col justify-between group">
           <div>
             <div class="w-12 h-12 bg-indigo-950/40 border border-indigo-500/10 rounded-2xl flex items-center justify-center text-2xl mb-6 group-hover:scale-110 transition-transform">
                <Icon name="mail" class="w-6 h-6 text-indigo-400" />
             </div>
             <h3 class="text-xl font-bold text-white mb-3">Newsletter Sponsorships</h3>
             <p class="text-sm text-gray-500 leading-relaxed">Reach our community of active automators in our weekly "WorkFlowAI Weekly" newsletter updates.</p>
           </div>
        </div>

         <!-- Feature 4 -->
        <div class="glass-card rounded-3xl p-8 border border-white/6 flex flex-col justify-between group">
           <div>
             <div class="w-12 h-12 bg-indigo-950/40 border border-indigo-500/10 rounded-2xl flex items-center justify-center text-2xl mb-6 group-hover:scale-110 transition-transform">
                <Icon name="users" class="w-6 h-6 text-indigo-400" />
             </div>
             <h3 class="text-xl font-bold text-white mb-3">Affiliate Integrations</h3>
             <p class="text-sm text-gray-500 leading-relaxed">We promote software that solves real bottlenecks. If your tool has an affiliate program, let's partner.</p>
           </div>
        </div>

      </div>

      <div class="text-center mt-16">
         <a href="/contact" class="btn btn-primary inline-flex justify-center items-center px-8 py-4">
            Let's Talk Partnerships
          </a>
      </div>

    </div>
  </div>
</Layout>
