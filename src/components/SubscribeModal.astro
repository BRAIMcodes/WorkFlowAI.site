---
---

<div id="subscribe-modal" class="fixed inset-0 z-[100] hidden" aria-labelledby="modal-title" role="dialog" aria-modal="true">
  <!-- Backdrop -->
  <div class="fixed inset-0 bg-black/70 backdrop-blur-md transition-opacity opacity-0" id="modal-backdrop"></div>

  <div class="fixed inset-0 z-10 w-screen overflow-y-auto">
    <div class="flex min-h-full items-end justify-center p-4 text-center sm:items-center sm:p-0">
      <!-- Modal Panel — Dark theme, matching site design system -->
      <div 
        class="relative transform overflow-hidden rounded-2xl text-left shadow-2xl transition-all sm:my-8 sm:w-full sm:max-w-md opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
        id="modal-panel"
        style="background: linear-gradient(145deg, rgba(15, 21, 37, 0.95) 0%, rgba(11, 15, 25, 0.98) 100%); border: 1px solid rgba(255,255,255,0.07);"
      >
        <!-- Decorative top shimmer -->
        <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-indigo-500/30 to-transparent"></div>
        
        <!-- Decorative glow -->
        <div class="absolute -top-20 -right-20 w-40 h-40 rounded-full bg-indigo-600/10 blur-[60px] pointer-events-none"></div>

        <!-- Close Button -->
        <div class="absolute right-4 top-4 z-10">
          <button 
            type="button" 
            id="close-modal-btn" 
            class="w-8 h-8 rounded-lg bg-white/5 hover:bg-white/10 border border-white/6 flex items-center justify-center text-gray-500 hover:text-white transition-all"
            aria-label="Close dialog"
          >
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        <div class="relative px-6 pb-6 pt-8 sm:px-8 sm:pb-8 sm:pt-10">
          <!-- Header -->
          <div class="text-center mb-6">
            <div class="w-12 h-12 mx-auto mb-4 rounded-xl bg-indigo-600/10 border border-indigo-500/20 flex items-center justify-center">
              <svg class="w-5 h-5 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <h3 class="font-display text-xl font-bold text-white mb-1.5" id="modal-title">
              Get Free Weekly Recipes
            </h3>
            <p class="text-sm text-gray-500 leading-relaxed">
              New AI workflow blueprints delivered to your inbox every week. No spam.
            </p>
          </div>

          <form id="subscribe-form" class="space-y-4">
            <div>
              <label for="subscribe-email" class="sr-only">Email address</label>
              <input 
                type="email" 
                name="email" 
                id="subscribe-email" 
                class="block w-full bg-[#0B0F19] border border-white/8 rounded-xl px-4 py-3 text-sm text-white placeholder-gray-600 focus:outline-none focus:border-indigo-500/50 focus:ring-1 focus:ring-indigo-500/20 transition-all"
                placeholder="you@company.com" 
                required
                autocomplete="email"
              >
            </div>

            <div class="flex items-start gap-3">
              <div class="flex h-5 items-center pt-0.5">
                <input 
                  id="subscribe-consent" 
                  name="consent" 
                  type="checkbox" 
                  class="h-3.5 w-3.5 rounded border-white/10 bg-white/5 text-indigo-500 focus:ring-indigo-500/30 focus:ring-offset-0 accent-indigo-500"
                  checked
                >
              </div>
              <label for="subscribe-consent" class="text-xs text-gray-500 leading-relaxed cursor-pointer select-none">
                Keep me updated with new workflows and automation insights.
              </label>
            </div>

            <button 
              type="submit" 
              id="subscribe-submit-btn" 
              class="btn btn-primary w-full justify-center py-3 text-sm"
            >
              Subscribe Free
            </button>

            <p id="subscribe-form-message" class="text-center text-xs mt-1 font-medium min-h-[1.25rem]"></p>
          </form>
          
          <p class="text-center text-[11px] text-gray-600 mt-3">
            We respect your privacy. Unsubscribe anytime.
          </p>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const modal = document.getElementById('subscribe-modal');
  const backdrop = document.getElementById('modal-backdrop');
  const panel = document.getElementById('modal-panel');
  const closeBtn = document.getElementById('close-modal-btn');
  const form = document.getElementById('subscribe-form') as HTMLFormElement;
  const message = document.getElementById('subscribe-form-message');
  const submitBtn = document.getElementById('subscribe-submit-btn') as HTMLButtonElement;

  function openModal() {
    if (!modal || !backdrop || !panel) return;
    modal.classList.remove('hidden');
    // Trigger reflow for transition
    requestAnimationFrame(() => {
      backdrop.classList.remove('opacity-0');
      panel.classList.remove('opacity-0', 'translate-y-4', 'sm:translate-y-0', 'sm:scale-95');
      panel.classList.add('opacity-100', 'translate-y-0', 'sm:scale-100');
    });
  }

  function closeModal() {
    if (!modal || !backdrop || !panel) return;
    backdrop.classList.add('opacity-0');
    panel.classList.remove('opacity-100', 'translate-y-0', 'sm:scale-100');
    panel.classList.add('opacity-0', 'translate-y-4', 'sm:translate-y-0', 'sm:scale-95');
    
    setTimeout(() => {
      modal.classList.add('hidden');
      if (message) {
        message.textContent = '';
        message.className = 'text-center text-xs mt-1 font-medium min-h-[1.25rem]';
      }
    }, 300);
  }

  // Form submission
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!submitBtn || !message) return;
    
    const originalText = submitBtn.textContent;
    submitBtn.textContent = 'Joining...';
    submitBtn.disabled = true;
    submitBtn.style.opacity = '0.7';
    message.textContent = '';

    const formData = new FormData(e.target as HTMLFormElement);
    
    try {
      const response = await fetch('/api/subscribe', {
        method: 'POST',
        body: formData
      });

      if (response.ok) {
        message.textContent = "You're in! Check your inbox.";
        message.className = 'text-center text-xs mt-1 font-medium text-emerald-400';
        form.reset();
        setTimeout(closeModal, 2500);
      } else {
        const data = await response.json();
        message.textContent = data.message || 'Something went wrong. Try again.';
        message.className = 'text-center text-xs mt-1 font-medium text-red-400';
      }
    } catch (err) {
      message.textContent = 'Connection error. Check your internet.';
      message.className = 'text-center text-xs mt-1 font-medium text-red-400';
    } finally {
      submitBtn.textContent = originalText;
      submitBtn.disabled = false;
      submitBtn.style.opacity = '1';
    }
  });

  // Close handlers
  closeBtn?.addEventListener('click', closeModal);
  
  modal?.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target === backdrop || target.closest('#modal-backdrop')) {
      closeModal();
    }
  });

  // Escape key to close
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal && !modal.classList.contains('hidden')) {
      closeModal();
    }
  });

  // Expose globally
  (window as any).openSubscribeModal = openModal;
</script>
